    <div id="toast-container" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] flex flex-col gap-2"></div>

    <script>
      // Sticky Navbar
      window.addEventListener('scroll', () => {
        const nav = document.getElementById('site-navbar');
        const credit = document.getElementById('nav-credit');
        const cartBtn = document.getElementById('nav-cart-btn');
        const logoLight = document.querySelector('.nav-logo-light');
        const logoDark = document.querySelector('.nav-logo-dark');

        if (window.scrollY > 40) {
          nav.classList.remove('bg-transparent', 'border-transparent', 'text-white', 'py-2');
          nav.classList.add('bg-white', 'border-gray-200', 'shadow-sm', 'text-gray-900', 'backdrop-blur-none');
          if (logoLight) logoLight.classList.add('hidden');
          if (logoDark) logoDark.classList.remove('hidden');
          if (credit) {
            credit.classList.remove('bg-primary/20', 'border-white/10');
            credit.classList.add('bg-primary', 'border-transparent');
          }
          if (cartBtn) {
            cartBtn.classList.remove('bg-white/10', 'hover:bg-white/20');
            cartBtn.classList.add('bg-gray-100', 'hover:bg-gray-200');
          }
        } else {
          nav.classList.add('bg-transparent', 'border-transparent', 'text-white');
          nav.classList.remove('bg-white', 'border-gray-200', 'shadow-sm', 'text-gray-900', 'backdrop-blur-none');
          if (logoLight) logoLight.classList.remove('hidden');
          if (logoDark) logoDark.classList.add('hidden');
          if (credit) {
            credit.classList.remove('bg-primary', 'border-transparent');
            credit.classList.add('bg-primary/20', 'border-white/10');
          }
          if (cartBtn) {
            cartBtn.classList.add('bg-white/10', 'hover:bg-white/20');
            cartBtn.classList.remove('bg-gray-100', 'hover:bg-gray-200');
          }
        }
      });

      // Mobile Menu Toggle Logic
      function toggleMobileMenu() {
        const overlay = document.getElementById('mobile-menu-overlay');
        const sidebar = document.getElementById('mobile-menu-sidebar');
        const isClosed = sidebar.classList.contains('-translate-x-full');

        if (isClosed) {
          // Open menu
          overlay.classList.remove('opacity-0', 'pointer-events-none');
          overlay.classList.add('opacity-100');
          sidebar.classList.remove('-translate-x-full');
          document.body.style.overflow = 'hidden';
        } else {
          // Close menu
          overlay.classList.remove('opacity-100');
          overlay.classList.add('opacity-0', 'pointer-events-none');
          sidebar.classList.add('-translate-x-full');
          document.body.style.overflow = '';
        }
      }

      // Toast Notification Logic
      function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = `px-6 py-3.5 rounded-full shadow-2xl text-sm font-bold text-white transform transition-all duration-300 translate-y-10 opacity-0 flex items-center gap-2 ${
          type === 'success' ? 'bg-green-500' : 'bg-primary'
        }`;

        const icon =
          type === 'success'
            ? `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`
            : `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;

        toast.innerHTML = icon + message;
        container.appendChild(toast);

        requestAnimationFrame(() => {
          toast.classList.remove('translate-y-10', 'opacity-0');
          toast.classList.add('translate-y-0', 'opacity-100');
        });

        setTimeout(() => {
          toast.classList.remove('translate-y-0', 'opacity-100');
          toast.classList.add('translate-y-10', 'opacity-0');
          setTimeout(() => toast.remove(), 300);
        }, 3000);
      }

      function copyIp(ip) {
        navigator.clipboard.writeText(ip);
        showToast('Sunucu adresi başarıyla kopyalandı!', 'success');
      }
    </script>

