<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title | default: shop.name }}</title>
    <meta name="description" content="{{ page_description | default: shop.name | append: ' - Minecraft Mağazası' }}">
    {{ content_for_header }}

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      :root {
        --color-primary: {{ settings.colors.primary | default: '#0056b3' }};
        --color-bg: {{ settings.colors.background | default: '#f8f9fa' }};
        --color-surface: {{ settings.colors.surface | default: '#ffffff' }};
        --color-border: {{ settings.colors.border | default: '#f3f4f6' }};
        --color-text-primary: {{ settings.colors.text_primary | default: '#111827' }};
        --color-text-secondary: {{ settings.colors.text_secondary | default: '#6b7280' }};
      }
    </style>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: 'var(--color-primary)',
              base: 'var(--color-bg)',
              white: 'var(--color-surface)',
              gray: {
                50: 'color-mix(in srgb, var(--color-surface) 96%, var(--color-text-primary) 4%)',
                100: 'var(--color-border)',
                200: 'color-mix(in srgb, var(--color-border) 90%, var(--color-text-primary) 10%)',
                300: 'color-mix(in srgb, var(--color-border) 70%, var(--color-text-secondary) 30%)',
                400: 'color-mix(in srgb, var(--color-text-secondary) 70%, var(--color-surface) 30%)',
                500: 'var(--color-text-secondary)',
                600: 'color-mix(in srgb, var(--color-text-secondary) 80%, var(--color-text-primary) 20%)',
                700: 'color-mix(in srgb, var(--color-text-primary) 70%, var(--color-text-secondary) 30%)',
                800: 'color-mix(in srgb, var(--color-text-primary) 90%, var(--color-text-secondary) 10%)',
                900: 'var(--color-text-primary)',
              }
            },
            fontFamily: {
              sans: ['Inter', 'sans-serif'],
              display: ['Rajdhani', 'sans-serif'],
            },
          },
        },
      };
    </script>

    <!-- Theme CSS -->
    <link rel="stylesheet" href="{{ 'assets/style.css' | asset_url }}">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- NProgress for smooth page transitions -->
    <link rel="stylesheet" href="https://unpkg.com/nprogress@0.2.0/nprogress.css">
    <script src="https://unpkg.com/nprogress@0.2.0/nprogress.js"></script>
    <style>
      #nprogress .bar {
        background: var(--color-primary) !important;
        height: 3px !important;
      }
      #nprogress .peg {
        box-shadow: 0 0 10px var(--color-primary), 0 0 5px var(--color-primary) !important;
      }
      #nprogress .spinner {
        display: none !important;
      }

      /* MPA View Transitions */
      @view-transition {
        navigation: auto;
      }
      @keyframes fade-in {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes fade-out {
        from {
          opacity: 1;
          transform: translateY(0);
        }
        to {
          opacity: 0;
          transform: translateY(-10px);
        }
      }
      ::view-transition-old(root) {
        animation: 200ms ease-out both fade-out;
      }
      ::view-transition-new(root) {
        animation: 200ms ease-out both fade-in;
      }

      /* Marquee Animation */
      @keyframes marquee {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }

      /* Float Animation */
      @keyframes shake-logo {
        0%,
        100% {
          transform: translate(-50%, -50%) translateY(0);
        }
        50% {
          transform: translate(-50%, -50%) translateY(-15px);
        }
      }
      .animate-shake-logo {
        animation: shake-logo 4s ease-in-out infinite;
      }
    </style>

    {% if settings.integrations.google_analytics_id != blank %}
      <!-- Global site tag (gtag.js) - Google Analytics -->
      <script
        async
        src="https://www.googletagmanager.com/gtag/js?id={{ settings.integrations.google_analytics_id }}"
      ></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag('js', new Date());
        gtag('config', '{{ settings.integrations.google_analytics_id }}');
      </script>
    {% endif %}
  </head>

  <body class="bg-base text-gray-900 flex flex-col min-h-screen antialiased selection:bg-primary selection:text-white">
    {% unless template == 'auth' or template contains 'auth/' %}
      <!-- NAVBAR SECTION (Fixed & Transparent -> Solid White) -->
      <header
        id="site-navbar"
        class="fixed top-0 w-full z-50 transition-all duration-300 bg-transparent border-b border-transparent text-white"
      >
        <div class="container max-w-[1400px] mx-auto px-4 flex items-center justify-between h-[70px]">
          <!-- Mobile Menu Toggle (Left on mobile) -->
          <button class="md:hidden flex items-center hover:opacity-75 transition-opacity" onclick="toggleMobileMenu()">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>

          <!-- Logo (Left on Desktop, Center on Mobile) -->
          <a href="/" class="flex items-center gap-3 hover:scale-105 transition-transform duration-300 hidden md:flex">
            {% assign default_logo = 'https://avatars.githubusercontent.com/u/3840546?s=280&v=4' %}
            <img
              src="{{ settings.logo_light | default: default_logo }}"
              alt="{{ shop.name }}"
              class="object-contain drop-shadow-md nav-logo-light"
              style="width: {{ settings.logo_width | default: 160 }}px; max-height: 50px;"
            >
            <img
              src="{{ settings.logo_dark | default: default_logo }}"
              alt="{{ shop.name }}"
              class="object-contain drop-shadow-md nav-logo-dark hidden"
              style="width: {{ settings.logo_width | default: 160 }}px; max-height: 50px;"
            >
          </a>

          <!-- Center: Navigation Links -->
          <nav class="hidden md:flex items-center gap-8 h-full">
            {% if settings.nav_links != blank %}
              {% for link in settings.nav_links %}
                {% assign is_active = false %}
                {% if link.url == '/' %}
                  {% if request.path == '/' or request.path == blank %}
                    {% assign is_active = true %}
                  {% endif %}
                {% elsif request.path contains link.url %}
                  {% assign is_active = true %}
                {% endif %}
                <a
                  href="{{ link.url }}"
                  class="h-full flex items-center text-[15px] font-bold transition-all relative group {% if is_active %}opacity-100{% else %}opacity-80 hover:opacity-100{% endif %}"
                  {% if link.new_tab %}
                    target="_blank"
                  {% endif %}
                >
                  {{ link.title }}
                  <span
                    class="absolute bottom-0 left-0 w-full h-[3px] bg-primary transition-transform origin-left {% if is_active %}scale-x-100{% else %}scale-x-0 group-hover:scale-x-100{% endif %}"
                  ></span>
                </a>
              {% endfor %}
            {% else %}
              <a
                href="/"
                class="h-full flex items-center text-[15px] font-bold transition-all relative group {% if request.path == '/' or request.path == blank %}opacity-100{% else %}opacity-80 hover:opacity-100{% endif %}"
              >
                Anasayfa
                <span
                  class="absolute bottom-0 left-0 w-full h-[3px] bg-primary transition-transform origin-left {% if request.path == '/' or request.path == blank %}scale-x-100{% else %}scale-x-0 group-hover:scale-x-100{% endif %}"
                ></span>
              </a>
              <a
                href="/store"
                class="h-full flex items-center text-[15px] font-bold transition-all relative group {% if request.path contains '/store' %}opacity-100{% else %}opacity-80 hover:opacity-100{% endif %}"
              >
                Mağaza
                <span
                  class="absolute bottom-0 left-0 w-full h-[3px] bg-primary transition-transform origin-left {% if request.path contains '/store' %}scale-x-100{% else %}scale-x-0 group-hover:scale-x-100{% endif %}"
                ></span>
              </a>
              <a
                href="/forum"
                class="h-full flex items-center text-[15px] font-bold transition-all relative group {% if request.path contains '/forum' %}opacity-100{% else %}opacity-80 hover:opacity-100{% endif %}"
              >
                Forum
                <span
                  class="absolute bottom-0 left-0 w-full h-[3px] bg-primary transition-transform origin-left {% if request.path contains '/forum' %}scale-x-100{% else %}scale-x-0 group-hover:scale-x-100{% endif %}"
                ></span>
              </a>
              <a
                href="/help"
                class="h-full flex items-center text-[15px] font-bold transition-all relative group {% if request.path contains '/yardim' %}opacity-100{% else %}opacity-80 hover:opacity-100{% endif %}"
              >
                Yardım
                <span
                  class="absolute bottom-0 left-0 w-full h-[3px] bg-primary transition-transform origin-left {% if request.path contains '/yardim' %}scale-x-100{% else %}scale-x-0 group-hover:scale-x-100{% endif %}"
                ></span>
              </a>
            {% endif %}
          </nav>

          <!-- Right: Auth Buttons & Cart -->
          <div class="flex items-center gap-4">
            <!-- Cart Button -->
            <a
              href="/cart"
              id="nav-cart-btn"
              class="relative p-2 transition-colors flex items-center justify-center bg-white/10 hover:bg-white/20 rounded-full"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
              <!-- Badge will be populated via JS from localStorage -->
              <span class="header-cart-badge hidden absolute -top-1 -right-1 w-4 h-4 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center shadow-sm"
                >0</span
              >
            </a>

            {% if customer %}
              <!-- Desktop Profile Dropdown (Hover) -->
              <div class="relative group hidden md:block py-4">
                <a
                  href="/profile"
                  class="flex items-center gap-2 text-sm font-bold hover:opacity-80 transition-opacity cursor-pointer"
                >
                  <img
                    src="https://mc-heads.net/avatar/{{ customer.username }}/32"
                    class="w-8 h-8 rounded-full border-2 border-white/20 shadow-sm"
                    alt=""
                  >
                  <span class="hidden sm:block drop-shadow-sm">{{ customer.username }}</span>
                  <span
                    id="nav-credit"
                    class="hidden lg:block ml-1 px-2 py-0.5 bg-primary/20 backdrop-blur-sm text-white rounded-md text-xs border border-white/10"
                  >
                    {{- customer.balance | default: '0' }} ₺</span
                  >
                </a>

                <!-- Dropdown Menu -->
                <div class="absolute right-0 top-[100%] w-72 bg-white rounded-2xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right translate-y-2 group-hover:translate-y-0 text-gray-800 z-[100]">
                  <!-- User Info -->
                  <div class="p-4 border-b border-gray-50 flex items-center gap-3">
                    <img
                      src="https://mc-heads.net/avatar/{{ customer.username }}/48"
                      class="w-12 h-12 rounded-full border-2 border-primary/20"
                      alt=""
                    >
                    <div class="overflow-hidden">
                      <div class="font-black text-gray-900 truncate">{{ customer.username }}</div>
                      <div class="text-xs font-bold text-gray-500 truncate">{{ customer.email }}</div>
                    </div>
                  </div>

                  <!-- Menu Grid -->
                  <div class="p-3 grid grid-cols-2 gap-2">
                    <a
                      href="/wallet"
                      class="flex flex-col items-center justify-center p-4 rounded-xl bg-gray-50 hover:bg-primary/5 hover:text-primary transition-colors text-center group/item border border-transparent hover:border-primary/10"
                    >
                      <svg
                        class="w-6 h-6 mb-2 text-gray-400 group-hover/item:text-primary transition-colors"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      <span class="text-xs font-bold">Kredi Yükle</span>
                    </a>

                    <a
                      href="/chest"
                      class="flex flex-col items-center justify-center p-4 rounded-xl bg-gray-50 hover:bg-primary/5 hover:text-primary transition-colors text-center group/item border border-transparent hover:border-primary/10"
                    >
                      <svg
                        class="w-6 h-6 mb-2 text-gray-400 group-hover/item:text-primary transition-colors"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                      </svg>
                      <span class="text-xs font-bold">Sandık</span>
                    </a>

                    <a
                      href="/profile"
                      class="flex flex-col items-center justify-center p-4 rounded-xl bg-gray-50 hover:bg-primary/5 hover:text-primary transition-colors text-center group/item border border-transparent hover:border-primary/10"
                    >
                      <svg
                        class="w-6 h-6 mb-2 text-gray-400 group-hover/item:text-primary transition-colors"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                      </svg>
                      <span class="text-xs font-bold">Profil</span>
                    </a>

                    <a
                      href="/profile/settings"
                      class="flex flex-col items-center justify-center p-4 rounded-xl bg-gray-50 hover:bg-primary/5 hover:text-primary transition-colors text-center group/item border border-transparent hover:border-primary/10"
                    >
                      <svg
                        class="w-6 h-6 mb-2 text-gray-400 group-hover/item:text-primary transition-colors"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      <span class="text-xs font-bold">Ayarlar</span>
                    </a>

                    {% if customer.role.permissions and customer.role.permissions.size > 0 %}
                      <a
                        href="https://app.crafter.net.tr/cms/auth?websiteId={{ customer.websiteId }}&accessToken={{ customer.access_token }}&refreshToken={{ customer.refresh_token }}"
                        class="col-span-2 flex items-center justify-center gap-2 p-3 rounded-xl bg-purple-50 hover:bg-purple-100 text-purple-600 transition-colors text-center border border-purple-100"
                      >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                        <span class="text-xs font-bold">Yönetim Paneli</span>
                      </a>
                    {% endif %}
                  </div>

                  <!-- Logout -->
                  <div class="p-3 border-t border-gray-50">
                    <button
                      onclick="logoutAccount()"
                      class="w-full flex items-center justify-center gap-2 p-3 rounded-xl hover:bg-red-50 text-red-500 transition-colors text-center text-xs font-bold"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                      </svg>
                      Çıkış Yap
                    </button>
                  </div>
                </div>
              </div>

              <!-- Mobile Auth Toggle -->
              <a
                href="/profile"
                class="md:hidden flex items-center gap-2 text-sm font-bold hover:opacity-80 transition-opacity"
              >
                <img
                  src="https://mc-heads.net/avatar/{{ customer.username }}/32"
                  class="w-8 h-8 rounded-full border-2 border-white/20 shadow-sm"
                  alt=""
                >
              </a>

            {% else %}
              <a
                href="/auth/sign-in"
                class="hidden sm:flex items-center gap-1.5 text-sm font-bold opacity-90 hover:opacity-100 transition-opacity drop-shadow-sm"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                Giriş Yap
              </a>
              <a
                href="/auth/sign-up"
                class="bg-primary text-white text-sm font-bold px-5 py-2 rounded-lg hover:brightness-110 transition-all shadow-md shadow-primary/30 border border-white/10"
              >
                Kayıt Ol
              </a>
            {% endif %}
          </div>
        </div>
      </header>

      <!-- Mobile Menu Overlay -->
      <div
        id="mobile-menu-overlay"
        class="fixed inset-0 z-[60] bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
        onclick="toggleMobileMenu()"
      ></div>

      <!-- Mobile Menu Sidebar -->
      <div
        id="mobile-menu-sidebar"
        class="fixed inset-y-0 left-0 z-[70] w-[85%] max-w-sm bg-white shadow-2xl transform -translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] flex flex-col"
      >
        <!-- Sidebar Header -->
        <div class="flex items-center justify-between p-6 border-b border-gray-100">
          {% assign default_logo = 'https://avatars.githubusercontent.com/u/3840546?s=280&v=4' %}
          <img
            src="{{ settings.logo_dark | default: default_logo }}"
            alt="{{ shop.name }}"
            class="object-contain"
            style="width: {{ settings.logo_width | default: 160 }}px; max-width: 140px; height: auto;"
          >
          <button
            onclick="toggleMobileMenu()"
            class="text-gray-400 hover:text-gray-900 bg-gray-50 hover:bg-gray-100 p-2 rounded-full transition-all"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- Navigation Links -->
        <div class="flex flex-col p-4 text-lg font-bold text-gray-600 overflow-y-auto flex-grow gap-1">
          {% if settings.nav_links != blank %}
            {% for link in settings.nav_links %}
              {% assign is_active = false %}
              {% if link.url == '/' %}
                {% if request.path == '/' or request.path == blank %}
                  {% assign is_active = true %}
                {% endif %}
              {% elsif request.path contains link.url %}
                {% assign is_active = true %}
              {% endif %}
              <a
                href="{{ link.url }}"
                class="flex items-center justify-between px-4 py-3.5 rounded-2xl hover:bg-gray-50 hover:text-primary transition-all {% if is_active %}text-primary bg-primary/5{% endif %}"
              >
                <span>{{ link.title }}</span>
                <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            {% endfor %}
          {% else %}
            <a
              href="/"
              class="flex items-center justify-between px-4 py-3.5 rounded-2xl hover:bg-gray-50 hover:text-primary transition-all {% if request.path == '/' or request.path == blank %}text-primary bg-primary/5{% endif %}"
            >
              <span>Ana Sayfa</span>
              <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
            <a
              href="/store"
              class="flex items-center justify-between px-4 py-3.5 rounded-2xl hover:bg-gray-50 hover:text-primary transition-all {% if request.path contains '/store' %}text-primary bg-primary/5{% endif %}"
            >
              <span>Mağaza</span>
              <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
            <a
              href="/forum"
              class="flex items-center justify-between px-4 py-3.5 rounded-2xl hover:bg-gray-50 hover:text-primary transition-all {% if request.path contains '/forum' %}text-primary bg-primary/5{% endif %}"
            >
              <span>Forum</span>
              <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          {% endif %}
        </div>

        <!-- User / Auth Info -->
        <div class="p-6 border-t border-gray-100 bg-gray-50/50">
          {% if customer %}
            <a
              href="/profile"
              class="flex items-center gap-4 bg-white p-4 rounded-2xl border border-gray-100 shadow-sm"
            >
              <img
                src="https://mc-heads.net/avatar/{{ customer.username }}/48"
                class="w-12 h-12 rounded-full border-2 border-primary/20"
                alt=""
              >
              <div class="flex-grow">
                <div class="font-black text-gray-900">{{ customer.username }}</div>
                <div class="text-xs font-bold text-gray-500">
                  Kredi: <span class="text-primary">{{ customer.balance | default: '0' }} ₺</span>
                </div>
              </div>
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          {% else %}
            <div class="flex flex-col gap-3">
              <a
