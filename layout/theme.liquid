    <script>
      // NProgress Page Load Handling
      NProgress.configure({ showSpinner: false });
      NProgress.done();
      
      async function logoutAccount() {
        try {
          await fetch('/api/storefront/v2/auth/logout', { method: 'POST' });
          window.location.reload();
        } catch (err) {
          window.location.reload();
        }
      }
      
      document.addEventListener('click', e => {
        const a = e.target.closest('a');
        if (a && a.href && !a.href.startsWith('#') && !a.target && a.host === window.location.host) {
          if (a.href !== window.location.href) NProgress.start();
        }
      });

      // Discord Widget Data Fetcher
      {% if settings.discord.guild_id != blank %}
      fetch('https://discord.com/api/guilds/{{ settings.discord.guild_id | default: '1256991995147190272' }}/widget.json')
        .then(res => res.json())
        .then(data => {
          if (data.presence_count !== undefined) {
            document.querySelectorAll('.discord-live-count').forEach(el => {
              const format = el.getAttribute('data-format') || '{count}';
              el.textContent = format.replace('{count}', data.presence_count);
            });
          }
          if (data.instant_invite) {
            document.querySelectorAll('.discord-invite-link').forEach(el => {
              el.href = data.instant_invite;
            });
          }
        })
        .catch(err => console.error('Discord API Hatası:', err));
      {% endif %}

      // MCAPI.TR Minecraft Server Status Fetcher
      const serverIp = '{{ settings.server_ip | default: "mc.hypixel.net" }}';
      if (serverIp) {
        const countEl = document.getElementById('server-player-count');
        
        async function fetchServerStatus() {
          try {
            const res = await fetch(`https://mcapi.tr/api/v1/status/${serverIp}`);
            if (!res.ok) throw new Error('MCAPI.TR error');
            const data = await res.json();
            if (data.online && data.players) {
              return data.players.online;
            }
          } catch (e) {
            console.warn('MCAPI.TR failed, trying fallback...', e);
            try {
              const res2 = await fetch(`https://api.mcsrvstat.us/3/${serverIp}`);
              if (!res2.ok) throw new Error('Fallback API error');
              const data2 = await res2.json();
              if (data2.online && data2.players) {
                return data2.players.online;
              }
            } catch (e2) {
              console.error('All APIs failed', e2);
            }
          }
          return null;
        }

        fetchServerStatus().then(online => {
          if (countEl) {
            if (online !== null) {
              countEl.textContent = `${online} ÇEVRİMİÇİ`;
            } else {
              countEl.textContent = 'BAKIMDA VEYA KAPALI';
            }
          }
        });
      }
    </script>
    <script>
      function updateGlobalCartBadge() {
        try {
          const cart = JSON.parse(localStorage.getItem('cart') || '[]');
          const count = cart.reduce((sum, item) => sum + (item.quantity || 1), 0);
          document.querySelectorAll('.header-cart-badge').forEach((el) => {
            el.innerText = count;
            if (count > 0) el.classList.remove('hidden');
            else el.classList.add('hidden');
          });
        } catch (e) {}
      }

      // Global Add to Cart function
      window.addToCart = function (product, quantity = 1) {
        try {
          const productId = product.id || product._id;
          if (!productId) return;

          let cart = JSON.parse(localStorage.getItem('cart') || '[]');
          const idx = cart.findIndex((i) => (i.id || i._id) === productId);
          if (idx !== -1) {
            cart[idx].quantity += quantity;
          } else {
            product.quantity = quantity;
            product.id = productId; // ensure standard id field
            cart.push(product);
          }
          localStorage.setItem('cart', JSON.stringify(cart));
          updateGlobalCartBadge();
          window.showToast?.('Ürün sepete eklendi!', 'success');
        } catch (e) {
          console.error(e);
        }
      };

      document.addEventListener('DOMContentLoaded', updateGlobalCartBadge);
      // Listen for local storage changes across tabs
      window.addEventListener('storage', (e) => {
        if (e.key === 'cart') updateGlobalCartBadge();
      });
    </script>

