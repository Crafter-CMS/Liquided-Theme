{% if customer %}
  <div class="container max-w-[1350px] mx-auto px-4 sm:px-6 py-8 sm:py-12 min-h-[60vh]">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Sol Kolon: Profil Bilgileri ve Navigasyon -->
      <div class="lg:col-span-4 space-y-6">
        <!-- Profil Kartı -->
        <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm relative overflow-hidden flex flex-col items-center text-center">
          <!-- Dekoratif Arkaplan -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-bl-[100px] -mr-8 -mt-8"></div>

          <div class="relative w-32 h-32 mb-6">
            <div class="absolute inset-0 bg-primary/20 rounded-full blur-xl"></div>
            <img
              src="https://mc-heads.net/avatar/{{ customer.username }}/128"
              alt="{{ customer.username }}"
              class="relative w-full h-full object-cover rounded-2xl shadow-md border-2 border-white"
            >
          </div>

          {% if customer.role %}
            <div
              class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-black uppercase tracking-wider mb-4 border"
              style="background-color: {{ customer.role.color }}15; color: {{ customer.role.color }}; border-color: {{ customer.role.color }}30;"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              {{ customer.role.name }}
            </div>
          {% endif %}

          <h1 class="text-3xl font-black text-gray-900 mb-2">{{ customer.username }}</h1>

          <div class="flex items-center justify-center gap-4 text-sm font-medium text-gray-500 mt-2">
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              Kayıt: {{ customer.createdAt | date: '%d.%m.%Y' }}
            </div>
          </div>
        </div>

        <!-- Navigasyon -->
        <div class="bg-white rounded-3xl p-6 border border-gray-100 shadow-sm">
          <h3 class="text-lg font-bold text-gray-900 mb-4">Menü</h3>
          <div class="space-y-2 flex flex-col">
            <a
              href="/profile"
              class="w-full flex items-center gap-3 p-4 rounded-2xl font-bold transition-all text-left text-gray-500 hover:bg-gray-50 border-2 border-transparent"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
              </svg>
              Profil Duvarı
            </a>
            <a
              href="/profile?tab=inventory"
              class="w-full flex items-center gap-3 p-4 rounded-2xl font-bold transition-all text-left text-gray-500 hover:bg-gray-50 border-2 border-transparent"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
              </svg>
              Envanterim
            </a>
            <a
              href="/profile/settings"
              class="w-full flex items-center gap-3 p-4 rounded-2xl font-bold transition-all text-left bg-primary/5 text-primary border-2 border-primary/20"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Ayarlar
            </a>
            <a
              href="/logout"
              class="w-full flex items-center gap-3 p-4 rounded-2xl font-bold transition-all text-left text-red-500 hover:bg-red-50 border-2 border-transparent"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
              Çıkış Yap
            </a>
          </div>
        </div>
      </div>

      <!-- Sağ Kolon: Ayarlar İçeriği -->
      <div class="lg:col-span-8">
        <div class="bg-white rounded-3xl p-6 md:p-8 border border-gray-100 shadow-sm">
          <h2 class="text-2xl font-black text-gray-900 mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Profil Ayarları
          </h2>

          <!-- Başarı Mesajı -->
          <div id="settings-success" class="hidden mb-6 p-4 rounded-xl bg-green-50 border border-green-200 text-green-700 font-bold flex items-center gap-3">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Değişiklikleriniz başarıyla kaydedildi!
          </div>
          
          <!-- Hata Mesajı -->
          <div id="settings-error" class="hidden mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 font-bold flex items-center gap-3">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span id="settings-error-text">Bir hata oluştu.</span>
          </div>

          <form id="settings-form" class="space-y-6 max-w-lg">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">Kullanıcı Adı</label>
              <input
                type="text"
                value="{{ customer.username }}"
                disabled
                class="w-full px-4 py-3 bg-gray-100 border border-gray-200 rounded-xl text-gray-500 font-medium cursor-not-allowed"
              >
              <p class="text-xs text-gray-400 mt-1 font-medium">Kullanıcı adı değiştirilemez.</p>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">E-posta Adresi</label>
              <input
                type="email"
                id="input-email"
                value="{{ customer.email }}"
                required
                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-gray-900 font-medium"
              >
            </div>

            <div class="pt-4 border-t border-gray-100">
              <h4 class="text-lg font-bold text-gray-900 mb-4">Şifre Değiştir</h4>
              <p class="text-xs text-gray-500 mb-4">Eğer şifrenizi değiştirmek istemiyorsanız bu alanları boş bırakabilirsiniz.</p>

              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-bold text-gray-700 mb-2">Yeni Şifre</label>
                  <input
                    type="password"
                    id="input-new-password"
                    placeholder="••••••••"
                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-gray-900 font-medium"
                  >
                </div>
              </div>
            </div>

            <div class="pt-6">
              <button
                type="submit"
                id="btn-save-settings"
                class="px-8 py-3.5 bg-primary hover:bg-primary/90 text-white font-bold rounded-xl transition-all shadow-md shadow-primary/20 w-full sm:w-auto disabled:opacity-50"
              >
                Değişiklikleri Kaydet
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('settings-form');
      const btnSave = document.getElementById('btn-save-settings');
      const inputEmail = document.getElementById('input-email');
      const inputPassword = document.getElementById('input-new-password');
      const successBox = document.getElementById('settings-success');
      const errorBox = document.getElementById('settings-error');
      const errorText = document.getElementById('settings-error-text');
      const customerId = '{{ customer.id }}';

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        successBox.classList.add('hidden');
        errorBox.classList.add('hidden');
        btnSave.disabled = true;
        btnSave.innerText = 'Kaydediliyor...';

        const email = inputEmail.value.trim();
        const password = inputPassword.value.trim();

        const updateData = { email };
        if (password) {
          updateData.password = password;
        }

        try {
          const res = await fetch(`/api/storefront/v2/users/${customerId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updateData)
          });
          
          const data = await res.json();
          
          if (res.ok && !data.error) {
            successBox.classList.remove('hidden');
            inputPassword.value = '';
          } else {
            errorText.innerText = data.message || data.error || 'Güncelleme sırasında bir hata oluştu.';
            errorBox.classList.remove('hidden');
          }
        } catch (err) {
          errorText.innerText = 'Sunucuyla bağlantı kurulamadı.';
          errorBox.classList.remove('hidden');
        } finally {
          btnSave.disabled = false;
          btnSave.innerText = 'Değişiklikleri Kaydet';
        }
      });
    });
  </script>
{% else %}
  <div class="min-h-[50vh] flex items-center justify-center">
    <div class="text-center">
      <h2 class="text-2xl font-black text-gray-900 mb-2">Giriş Yapmalısınız</h2>
      <p class="text-gray-500 font-medium mb-6">Ayarlarınızı görüntülemek için hesabınıza giriş yapmanız gerekmektedir.</p>
      <a href="/auth" class="px-8 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 transition-colors shadow-md">Giriş Yap</a>
    </div>
  </div>
{% endif %}
