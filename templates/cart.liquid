<div class="container max-w-[1400px] mx-auto px-4 mt-8 mb-24 space-y-8 min-h-[50vh]">
  <!-- Breadcrumb -->
  <div class="flex flex-wrap items-center gap-2 text-sm font-bold text-gray-500 bg-white py-3 px-6 rounded-2xl w-fit shadow-sm border border-gray-100">
    <a href="/store" class="hover:text-primary transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
    </a>
    <span>/</span>
    <span class="text-gray-900">Sepetim</span>
  </div>

  <div id="cart-loading" class="flex flex-col items-center justify-center py-20">
    <svg class="w-12 h-12 text-primary animate-spin mb-4" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
    <div class="font-bold text-gray-500">Sepetiniz yükleniyor...</div>
  </div>

  <div
    id="cart-empty"
    class="hidden bg-white rounded-3xl shadow-sm border border-gray-100 p-16 text-center flex-col items-center"
  >
    <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
      </svg>
    </div>
    <h3 class="text-2xl font-black text-gray-900 mb-2">Sepetiniz boş</h3>
    <p class="text-gray-500 font-medium mb-8">
      Henüz sepetinize ürün eklemediniz. Mağazamızı keşfedin ve favori ürünlerinizi sepete ekleyin.
    </p>
    <a
      href="/store"
      class="inline-flex items-center gap-2 bg-primary text-white font-bold rounded-xl px-8 py-4 hover:brightness-110 transition-all shadow-md shadow-primary/20"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
      </svg>
      Mağazaya Git
    </a>
  </div>

  <div id="cart-content" class="hidden grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8">
    <!-- Products List -->
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden h-fit">
      <div class="p-6 border-b border-gray-100 flex items-center justify-between bg-gray-50/50">
        <h2 class="text-xl font-black text-gray-900 flex items-center gap-2">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          Sepet Ürünleri (<span id="cart-count">0</span>)
        </h2>
        <button
          id="clearCartBtn"
          onclick="clearCart(this)"
          class="text-sm font-bold text-red-500 hover:text-red-600 transition-colors bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg flex items-center gap-1.5"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Temizle
        </button>
      </div>
      <div id="cart-items" class="divide-y divide-gray-100">
        <!-- JS rendered items -->
      </div>
    </div>

    <!-- Order Summary -->
    <div class="space-y-6">
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sticky top-24">
        <h2 class="text-xl font-black text-gray-900 mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          Sipariş Özeti
        </h2>

        <!-- Coupon Form -->
        <div class="mb-6 pb-6 border-b border-gray-100">
          <div
            id="applied-coupon"
            class="hidden mb-4 p-4 bg-green-50 border border-green-200 rounded-2xl relative overflow-hidden"
          >
            <div
              class="absolute top-0 right-0 w-16 h-16 bg-green-500/10 rounded-full blur-xl transform translate-x-1/2 -translate-y-1/2"
            ></div>
            <div class="flex items-center justify-between relative z-10">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div class="font-bold text-green-800" id="coupon-code-display"></div>
              </div>
              <button
                onclick="removeCoupon()"
                class="text-green-600 hover:text-green-800 transition-colors p-1 bg-green-100 hover:bg-green-200 rounded-lg"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
            </div>
            <div class="text-xs font-semibold text-green-700 mt-2" id="coupon-description"></div>
          </div>

          <div id="coupon-input-container" class="flex items-center gap-2">
            <div class="relative flex-1">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                </svg>
              </div>
              <input
                type="text"
                id="couponCode"
                class="w-full pl-10 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-medium text-gray-900 placeholder:text-gray-400"
                placeholder="Kupon kodunuz"
              >
            </div>
            <button
              onclick="applyCoupon()"
              id="applyCouponBtn"
              class="bg-gray-900 text-white font-bold rounded-xl px-4 py-3 hover:bg-gray-800 transition-colors flex-shrink-0"
            >
              Uygula
            </button>
          </div>
        </div>

        <div class="space-y-4 mb-6 text-base">
          <div class="flex items-center justify-between font-medium text-gray-500">
            <span>Ara Toplam</span>
            <span id="subtotal" class="font-bold text-gray-900">0.00 ₺</span>
          </div>
          <div id="coupon-discount-row" class="hidden items-center justify-between font-medium text-green-600">
            <span>Kupon İndirimi</span>
            <span id="coupon-discount" class="font-bold">-0.00 ₺</span>
          </div>
        </div>

        <div class="border-t border-gray-100 pt-6 mb-8">
          <div class="flex items-center justify-between">
            <span class="text-lg font-bold text-gray-900">Toplam</span>
            <span id="total" class="text-2xl font-black text-primary">0.00 ₺</span>
          </div>
        </div>

        <button
          onclick="purchase()"
          id="purchaseBtn"
          class="w-full bg-primary text-white font-bold rounded-xl px-8 py-4 hover:brightness-110 transition-all shadow-lg shadow-primary/30 flex items-center justify-center gap-2 text-lg disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          Siparişi Tamamla
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Marketplace Settings injected from server
  const bulkDiscount = {{ marketplace.bulkDiscount | json | default: 'null' }};
  const isCustomer = {% if customer %}true{% else %}false{% endif %};
  
  let cartProducts = [];
  let appliedCoupon = null;

  async function loadCart() {
    const cartStr = localStorage.getItem('cart');
    let cart = [];
    if (cartStr) {
      try {
        cart = JSON.parse(cartStr);
        // Filtrele: ID'si boş olan hatalı kayıtları temizle
        const originalLength = cart.length;
        cart = cart.filter(item => item && item.id && item.id.trim() !== '');
        if (cart.length !== originalLength) {
          localStorage.setItem('cart', JSON.stringify(cart));
        }
      } catch(e){}
    }

    if (cart.length === 0) {
      document.getElementById('cart-loading').classList.add('hidden');
      document.getElementById('cart-empty').classList.remove('hidden');
      document.getElementById('cart-content').classList.add('hidden');
      updateCartHeaderCount();
      return;
    }

    try {
      // Artık API'den ürünleri tek tek çekmiyoruz (N+1 problemi çözüldü)
      // Ürün objeleri doğrudan sepete eklenirken localStorage'a kaydediliyor.
      cartProducts = cart;

      document.getElementById('cart-loading').classList.add('hidden');
      
      if (cartProducts.length === 0) {
        document.getElementById('cart-empty').classList.remove('hidden');
        document.getElementById('cart-content').classList.add('hidden');
      } else {
        document.getElementById('cart-empty').classList.add('hidden');
        document.getElementById('cart-content').classList.remove('hidden');
        renderCart();
      }
    } catch(err) {
      console.error(err);
      document.getElementById('cart-loading').classList.add('hidden');
      window.showToast?.('Sepet yüklenirken hata oluştu', 'error');
    }
  }

  function renderCart() {
    const itemsContainer = document.getElementById('cart-items');
    itemsContainer.innerHTML = '';
    
    let totalSubtotal = 0;

    cartProducts.forEach(product => {
      const originalPrice = Number(product.price) || 0;
      const discountValue = Number(product.discountValue) || 0;
      const hasProductDiscount = discountValue > 0;
      
      let productDiscountedPrice = originalPrice;
      if (hasProductDiscount) {
        productDiscountedPrice = product.discountType === 'percentage'
          ? originalPrice - (originalPrice * discountValue / 100)
          : originalPrice - discountValue;
      }

      let bulkDiscountedPrice = originalPrice;
      let hasBulk = false;
      let bulkDiscountAmount = 0;

      if (bulkDiscount && bulkDiscount.amount > 0 && (!bulkDiscount.products || bulkDiscount.products.length === 0 || bulkDiscount.products.includes(product.id))) {
        hasBulk = true;
        if (bulkDiscount.type === 'percentage') {
          bulkDiscountAmount = (originalPrice * bulkDiscount.amount) / 100;
        } else {
          bulkDiscountAmount = bulkDiscount.amount;
        }
        bulkDiscountedPrice = originalPrice - bulkDiscountAmount;
      }

      let finalPrice = originalPrice;
      let badgeHtml = '';

      if (hasProductDiscount && hasBulk) {
        if (bulkDiscountedPrice < productDiscountedPrice) {
          finalPrice = bulkDiscountedPrice;
          badgeHtml = `<span class="px-2 py-0.5 bg-red-100 text-red-600 rounded text-xs font-bold">${bulkDiscount.type === 'percentage' ? `%${bulkDiscount.amount} İndirim` : `${bulkDiscount.amount}₺ İndirim`}</span>`;
        } else {
          finalPrice = productDiscountedPrice;
          badgeHtml = `<span class="px-2 py-0.5 bg-red-100 text-red-600 rounded text-xs font-bold">${product.discountType === 'percentage' ? `%${discountValue} İndirim` : `${discountValue}₺ İndirim`}</span>`;
        }
      } else if (hasBulk) {
        finalPrice = bulkDiscountedPrice;
        badgeHtml = `<span class="px-2 py-0.5 bg-red-100 text-red-600 rounded text-xs font-bold">${bulkDiscount.type === 'percentage' ? `%${bulkDiscount.amount} İndirim` : `${bulkDiscount.amount}₺ İndirim`}</span>`;
      } else if (hasProductDiscount) {
        finalPrice = productDiscountedPrice;
        badgeHtml = `<span class="px-2 py-0.5 bg-red-100 text-red-600 rounded text-xs font-bold">${product.discountType === 'percentage' ? `%${discountValue} İndirim` : `${discountValue}₺ İndirim`}</span>`;
      }

      let couponDiscount = 0;
      let hasCouponDiscount = false;
      if (appliedCoupon && appliedCoupon.type === 'product_discount') {
        if (!appliedCoupon.productId || product.id === appliedCoupon.productId) {
          hasCouponDiscount = true;
          if (appliedCoupon.discountType === 'percentage') {
            couponDiscount = (finalPrice * appliedCoupon.discountValue) / 100;
          } else {
            couponDiscount = appliedCoupon.discountValue;
          }
        }
      }

      const finalPriceWithCoupon = finalPrice - couponDiscount;
      const lineTotal = finalPriceWithCoupon * product.quantity;
      totalSubtotal += lineTotal;

      const imgUrl = product.image;
      const imgHtml = imgUrl ? `<img src="${imgUrl}" class="w-full h-full object-contain p-2" alt="">` : `<div class="flex items-center justify-center text-gray-300 h-full"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg></div>`;

      let priceHtml = '';
      if (finalPrice < originalPrice || hasCouponDiscount) {
        priceHtml = `
          <div class="flex items-center gap-2 mt-1 flex-wrap">
            <span class="text-sm text-gray-400 line-through font-medium">${originalPrice.toFixed(2)} ₺</span>
            <span class="font-black text-gray-900">${Math.max(0, finalPriceWithCoupon).toFixed(2)} ₺</span>
            ${badgeHtml}
            ${hasCouponDiscount ? `<span class="px-2 py-0.5 bg-green-100 text-green-600 rounded text-xs font-bold">Kuponlu</span>` : ''}
          </div>
        `;
      } else {
        priceHtml = `<div class="font-black text-gray-900 mt-1">${originalPrice.toFixed(2)} ₺</div>`;
      }

      itemsContainer.innerHTML += `
        <div class="flex items-center gap-6 p-6 hover:bg-gray-50/50 transition-colors">
          <div class="w-20 h-20 bg-gray-50 rounded-2xl border border-gray-100 flex-shrink-0">
            ${imgHtml}
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-bold text-gray-900 truncate"><a href="/store/product/${product.id}" class="hover:text-primary transition-colors">${product.name}</a></h3>
            ${priceHtml}
          </div>
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-1 bg-gray-50 border border-gray-200 rounded-xl p-1">
              <button onclick="updateQty('${product.id}', ${product.quantity - 1})" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white hover:shadow-sm text-gray-600 transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg></button>
              <span class="w-8 text-center font-bold text-gray-900">${product.quantity}</span>
              <button onclick="updateQty('${product.id}', ${product.quantity + 1})" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white hover:shadow-sm text-gray-600 transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg></button>
            </div>
            <div class="w-24 text-right">
              <span class="font-black text-primary text-lg">${Math.max(0, lineTotal).toFixed(2)} ₺</span>
            </div>
            <button onclick="removeFromCart('${product.id}')" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-red-50 text-gray-400 hover:text-red-500 transition-colors flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </div>
        </div>
      `;
    });

    document.getElementById('cart-count').innerText = cartProducts.length;

    let cartCouponDiscount = 0;
    if (appliedCoupon && appliedCoupon.type === 'cart_discount') {
      cartCouponDiscount = appliedCoupon.discountType === 'percentage'
        ? (totalSubtotal * appliedCoupon.discountValue) / 100
        : appliedCoupon.discountValue;
    }

    const grandTotal = Math.max(0, totalSubtotal - cartCouponDiscount);

    document.getElementById('subtotal').innerText = `${totalSubtotal.toFixed(2)} ₺`;
    if (cartCouponDiscount > 0) {
      document.getElementById('coupon-discount-row').classList.remove('hidden');
      document.getElementById('coupon-discount-row').classList.add('flex');
      document.getElementById('coupon-discount').innerText = `-${cartCouponDiscount.toFixed(2)} ₺`;
    } else {
      document.getElementById('coupon-discount-row').classList.add('hidden');
      document.getElementById('coupon-discount-row').classList.remove('flex');
    }
    
    document.getElementById('total').innerText = `${grandTotal.toFixed(2)} ₺`;
    
    updateCartHeaderCount();
  }

  function updateQty(id, newQty) {
    if (newQty < 1) {
      removeFromCart(id);
      return;
    }
    const idx = cartProducts.findIndex(p => p.id === id);
    if (idx !== -1) {
      cartProducts[idx].quantity = newQty;
      saveCart();
      renderCart();
    }
  }

  function removeFromCart(id) {
    cartProducts = cartProducts.filter(p => p.id !== id);
    saveCart();
    if (cartProducts.length === 0) {
      loadCart(); // will trigger empty state
    } else {
      renderCart();
    }
  }

  let clearCartTimeout;
  function clearCart(btn) {
    if (btn.classList.contains('confirm-mode')) {
      cartProducts = [];
      appliedCoupon = null;
      saveCart();
      loadCart();
      
      btn.classList.remove('confirm-mode', 'bg-red-500', 'text-white', 'hover:bg-red-600');
      btn.classList.add('bg-red-50', 'text-red-500', 'hover:bg-red-100', 'hover:text-red-600');
      btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg> Temizle`;
      clearTimeout(clearCartTimeout);
    } else {
      btn.classList.add('confirm-mode', 'bg-red-500', 'text-white', 'hover:bg-red-600');
      btn.classList.remove('bg-red-50', 'text-red-500', 'hover:bg-red-100', 'hover:text-red-600');
      btn.innerHTML = `<svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> Emin misin?`;
      
      clearCartTimeout = setTimeout(() => {
        btn.classList.remove('confirm-mode', 'bg-red-500', 'text-white', 'hover:bg-red-600');
        btn.classList.add('bg-red-50', 'text-red-500', 'hover:bg-red-100', 'hover:text-red-600');
        btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg> Temizle`;
      }, 3000);
    }
  }

  function saveCart() {
    const minCart = cartProducts.map(p => ({ id: p.id, quantity: p.quantity }));
    localStorage.setItem('cart', JSON.stringify(minCart));
    updateCartHeaderCount();
  }

  function updateCartHeaderCount() {
    // If you added a cart icon to header, update its badge here
    const minCart = JSON.parse(localStorage.getItem('cart') || '[]');
    const badges = document.querySelectorAll('.header-cart-badge');
    badges.forEach(b => {
      b.innerText = minCart.length;
      if (minCart.length > 0) b.classList.remove('hidden');
      else b.classList.add('hidden');
    });
  }

  async function applyCoupon() {
    const code = document.getElementById('couponCode').value.trim();
    if (!code) return;
    
    const btn = document.getElementById('applyCouponBtn');
    const ogText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '...';

    try {
      const res = await fetch(`/api/storefront/v1/coupons/${code}`);
      const data = await res.json();
      
      if (data && data.success && data.data) {
        const c = data.data;
        if (!c.isActive) {
          window.showToast?.('Kupon artık aktif değil.', 'error');
          return;
        }

        const currentSubtotal = cartProducts.reduce((sum, p) => sum + (Number(p.price) || 0) * p.quantity, 0);
        if (c.minCartValue && currentSubtotal < c.minCartValue) {
          window.showToast?.(`Minimum sepet tutarı: ${c.minCartValue}₺`, 'warning');
          return;
        }

        if (c.type === 'product_discount' && c.productId) {
          if (!cartProducts.some(p => p.id === c.productId)) {
            window.showToast?.('Bu kupon sepetinizdeki ürünler için geçerli değil.', 'error');
            return;
          }
        }

        appliedCoupon = c;
        document.getElementById('coupon-input-container').classList.add('hidden');
        document.getElementById('applied-coupon').classList.remove('hidden');
        document.getElementById('coupon-code-display').innerText = c.code;
        
        let desc = 'İndirim uygulandı';
        if (c.type === 'product_discount') desc = `Belirli ürünlere ${c.discountType==='percentage'?`%${c.discountValue}`:`${c.discountValue}₺`} indirim`;
        if (c.type === 'cart_discount') desc = `Sepete ${c.discountType==='percentage'?`%${c.discountValue}`:`${c.discountValue}₺`} indirim`;
        if (c.type === 'free_product') desc = `Ücretsiz ürün hediyesi!`;
        
        document.getElementById('coupon-description').innerText = desc;
        renderCart();
        window.showToast?.('Kupon uygulandı!', 'success');
      } else {
        window.showToast?.(data.message || 'Geçersiz kupon kodu.', 'error');
      }
    } catch (e) {
      window.showToast?.('Kupon kontrol edilemedi.', 'error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = ogText;
    }
  }

  function removeCoupon() {
    appliedCoupon = null;
    document.getElementById('couponCode').value = '';
    document.getElementById('coupon-input-container').classList.remove('hidden');
    document.getElementById('applied-coupon').classList.add('hidden');
    renderCart();
  }

  let purchaseTimeout;
  async function purchase() {
    if (!isCustomer) {
      window.location.href = '/auth/sign-in?return=/cart';
      return;
    }

    if (cartProducts.length === 0) return;

    const btn = document.getElementById('purchaseBtn');
    const ogText = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg> Siparişi Tamamla';

    if (!btn.classList.contains('confirm-mode')) {
      btn.classList.add('confirm-mode', 'bg-green-600');
      btn.classList.remove('bg-primary');
      btn.innerHTML = '<svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Onaylıyor musunuz?';
      
      purchaseTimeout = setTimeout(() => {
        btn.classList.remove('confirm-mode', 'bg-green-600');
        btn.classList.add('bg-primary');
        btn.innerHTML = ogText;
      }, 3000);
      return;
    }
    
    clearTimeout(purchaseTimeout);
    btn.disabled = true;
    btn.classList.remove('bg-green-600');
    btn.classList.add('bg-primary');
    btn.innerHTML = '<svg class="w-5 h-5 animate-spin mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> İşleniyor...';

    try {
      const productIds = cartProducts.map(p => p.id);
      const payload = { productIds };
      if (appliedCoupon) payload.coupon = appliedCoupon.code;

      const res = await fetch('/api/storefront/v1/marketplace/purchase', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();

      if (data.success || res.ok) {
        window.showToast?.('Sipariş başarıyla tamamlandı! Sandığa yönlendiriliyorsunuz.', 'success');
        localStorage.removeItem('cart');
        setTimeout(() => {
          window.location.href = '/chest';
        }, 2000);
      } else {
        window.showToast?.(data.message || 'Sipariş tamamlanamadı.', 'error');
        btn.disabled = false;
        btn.innerHTML = ogText;
      }
    } catch (e) {
      window.showToast?.('Bağlantı hatası.', 'error');
      btn.disabled = false;
      btn.innerHTML = ogText;
    }
  }

  document.addEventListener('DOMContentLoaded', loadCart);
</script>
