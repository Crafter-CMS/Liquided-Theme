<div class="container max-w-[1400px] mx-auto px-4 mt-8 mb-24 space-y-8 min-h-[60vh]">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm font-bold text-gray-500 bg-white py-3 px-6 rounded-2xl w-fit shadow-sm border border-gray-100">
    <a href="/" class="hover:text-primary transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
    </a>
    <span>/</span>
    <a href="/applications" class="hover:text-gray-900 transition-colors">Başvurular</a>
    <span>/</span>
    <span class="text-gray-900">{{ formDetail.title }}</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[300px_1fr] gap-8">
    <!-- Sol Panel: Form Detayları -->
    <aside class="space-y-6">
      <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm">
        <h3 class="text-lg font-black text-gray-900 mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Form Bilgileri
        </h3>

        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-bold text-gray-400">Durum</span>
            {% if formDetail.isActive %}
              <span class="px-2.5 py-1 bg-green-50 text-green-600 rounded-lg border border-green-100 text-xs font-bold"
                >Aktif</span
              >
            {% else %}
              <span class="px-2.5 py-1 bg-gray-50 text-gray-500 rounded-lg border border-gray-200 text-xs font-bold"
                >Pasif</span
              >
            {% endif %}
          </div>

          <div class="flex items-center justify-between">
            <span class="text-sm font-bold text-gray-400">Soru Sayısı</span>
            <span class="text-sm font-black text-gray-900">{{ formDetail.inputs.size }}</span>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-sm font-bold text-gray-400">Tarih</span>
            <span class="text-sm font-black text-gray-900">{{ formDetail.createdAt | date: '%d.%m.%Y' }}</span>
          </div>
        </div>
      </div>
    </aside>

    <!-- Sağ Panel: Form İçeriği -->
    <main>
      <div class="bg-white border border-gray-100 rounded-3xl p-6 md:p-10 shadow-sm relative overflow-hidden">
        <div class="mb-8">
          <h2 class="text-2xl sm:text-3xl font-black text-gray-900 mb-2">{{ formDetail.title }}</h2>
          <p class="text-gray-500 font-medium">{{ formDetail.description }}</p>
        </div>

        {% if formDetail.isActive %}
          <!-- Başarı Mesajı -->
          <div
            id="apply-success"
            class="hidden absolute inset-0 bg-white z-10 flex flex-col items-center justify-center p-8 text-center animate-[fade-in-up_0.3s_ease-out]"
          >
            <div class="w-20 h-20 bg-green-50 border border-green-100 rounded-full flex items-center justify-center mb-6">
              <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-2xl font-black text-gray-900 mb-2">Başvurunuz Gönderildi!</h3>
            <p class="text-gray-500 font-medium max-w-md mb-8">
              Form başarıyla iletildi. Yetkililerimiz başvurunuzu inceledikten sonra gerekli durumlarda sizinle
              iletişime geçecektir.
            </p>
            <a
              href="/applications"
              class="px-8 py-4 bg-gray-900 hover:bg-gray-800 text-white font-bold rounded-2xl transition-all shadow-md"
            >
              Başvurularıma Dön
            </a>
          </div>

          <!-- Hata Mesajı -->
          <div
            id="apply-error"
            class="hidden mb-8 p-6 rounded-2xl bg-red-50 border border-red-100 flex items-start gap-4"
          >
            <div class="w-12 h-12 rounded-xl bg-red-100 text-red-600 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-lg font-black text-red-900 mb-1">Gönderim Başarısız</h4>
              <p id="apply-error-text" class="text-red-700 font-medium">
                Lütfen tüm alanları doldurduğunuzdan emin olun.
              </p>
            </div>
          </div>

          <form id="application-form" class="space-y-6">
            {% for input in formDetail.inputs %}
              <div class="space-y-2">
                <label class="block text-sm font-bold text-gray-900">
                  {{ input.name }}
                  <span class="text-red-500">*</span>
                </label>

                {% if input.type == 'textarea' %}
                  <textarea
                    name="{{ input.name }}"
                    required
                    rows="4"
                    placeholder="{{ input.name }} giriniz..."
                    class="w-full px-5 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-gray-900 font-medium resize-none"
                  ></textarea>
                {% elsif input.type == 'checkbox' %}
                  <label class="flex items-center gap-3 cursor-pointer p-4 rounded-xl border border-gray-100 bg-gray-50 hover:bg-gray-100 transition-colors w-fit">
                    <input
                      type="checkbox"
                      name="{{ input.name }}"
                      class="w-5 h-5 rounded-md border-gray-300 text-primary focus:ring-primary"
                    >
                    <span class="text-sm font-bold text-gray-900 select-none">Kabul ediyorum</span>
                  </label>
                {% else %}
                  <input
                    type="{% if input.type == 'datetime' %}datetime-local{% elsif input.type == 'phone' %}tel{% else %}{{ input.type }}{% endif %}"
                    name="{{ input.name }}"
                    required
                    placeholder="{{ input.name }} giriniz..."
                    class="w-full px-5 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-gray-900 font-medium"
                  >
                {% endif %}
              </div>
            {% endfor %}

            <div class="pt-6 border-t border-gray-100 flex items-center justify-end gap-4 mt-8">
              <a href="/applications" class="px-6 py-4 font-bold text-gray-500 hover:text-gray-900 transition-colors">
                İptal Et
              </a>
              <button
                type="submit"
                id="btn-submit"
                class="px-8 py-4 bg-primary text-white font-black rounded-2xl hover:brightness-110 transition-all shadow-md shadow-primary/30 flex items-center gap-2"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                Başvuruyu Gönder
              </button>
            </div>
          </form>
        {% else %}
          <div class="bg-red-50 border border-red-100 rounded-2xl p-6 flex items-start gap-4">
            <div class="w-12 h-12 bg-red-100 text-red-600 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-black text-red-900 mb-1">Form Kapalı</h3>
              <p class="text-red-700 font-medium">Bu form şu anda aktif değildir ve yeni başvuru kabul etmemektedir.</p>
              <a
                href="/applications"
                class="inline-block mt-4 text-sm font-bold text-red-800 hover:text-red-900 underline"
                >Başvurular sayfasına dön</a
              >
            </div>
          </div>
        {% endif %}
      </div>
    </main>
  </div>
</div>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('application-form');
    if (!form) return;

    const btnSubmit = document.getElementById('btn-submit');
    const boxSuccess = document.getElementById('apply-success');
    const boxError = document.getElementById('apply-error');
    const textError = document.getElementById('apply-error-text');
    const formId = '{{ formDetail.id | default: formDetail._id }}';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      boxError.classList.add('hidden');
      
      const formData = new FormData(form);
      const values = [];

      // Collect values dynamically based on input names
      {% for input in formDetail.inputs %}
        (function() {
          const inputName = `{{ input.name }}`;
          const inputType = `{{ input.type }}`;
          let val = formData.get(inputName);
          
          if (inputType === 'checkbox') {
            const cb = form.querySelector(`input[name="${inputName.replace(/"/g, '\\"')}"]`);
            val = (cb && cb.checked) ? "true" : "false";
          }
          
          if (val !== null && val !== undefined) {
            values.push({
              inputId: inputName,
              value: val.toString()
            });
          }
        })();
      {% endfor %}

      btnSubmit.disabled = true;
      btnSubmit.innerHTML = `
        <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        Gönderiliyor...
      `;

      try {
        const res = await fetch(`/api/storefront/staff-forms/${formId}/apply`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ values })
        });
        
        const data = await res.json();
        
        if (res.ok && !data.error) {
          boxSuccess.classList.remove('hidden');
          boxSuccess.classList.add('flex');
        } else {
          boxError.classList.remove('hidden');
          textError.innerText = data.message || data.error || 'Başvuru gönderilirken bir hata oluştu.';
        }
      } catch (err) {
        boxError.classList.remove('hidden');
        textError.innerText = 'Sunucuyla bağlantı kurulamadı.';
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerHTML = `
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          Başvuruyu Gönder
        `;
      }
    });
  });
</script>
