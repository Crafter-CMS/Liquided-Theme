<div class="container max-w-[1400px] mx-auto px-4 mt-8 mb-24 space-y-8 min-h-[60vh]">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm font-bold text-gray-500 bg-white py-3 px-6 rounded-2xl w-fit shadow-sm border border-gray-100">
    <a href="/" class="hover:text-primary transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
    </a>
    <span>/</span>
    <span class="text-gray-900">Oy Ver</span>
  </div>

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-black text-gray-900 tracking-tight">Sunucuya Oy Ver</h1>
    <p class="text-gray-500 mt-2">Sunucumuza oy vererek hem bize destek olabilir, hem de birbirinden değerli ödüller kazanabilirsiniz!</p>
    
    {% assign can_vote = true %}
    {% if customer.nextVoteAt %}
      <script>
        (function() {
          const nextVote = new Date('{{ customer.nextVoteAt }}');
          if (nextVote > new Date()) {
            document.write(`
              <div class="mt-4 bg-yellow-50 border border-yellow-100 rounded-xl p-3 w-fit flex items-center gap-3 shadow-sm">
                <div class="flex items-center gap-2 text-yellow-700 font-black">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Bekleme Süresi
                </div>
                <div class="text-yellow-600 text-sm font-bold border-l border-yellow-200 pl-3">
                  Sonraki oy: ${nextVote.toLocaleString('tr-TR')}
                </div>
              </div>
            `);
          } else {
            document.write(`
              <div class="mt-4 bg-green-50 border border-green-100 rounded-xl p-3 w-fit flex items-center gap-2 shadow-sm text-green-700 font-black">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Şimdi Oy Verebilirsiniz
              </div>
            `);
          }
        })();
      </script>
    {% else %}
      <div class="mt-4 bg-green-50 border border-green-100 rounded-xl p-3 w-fit flex items-center gap-2 shadow-sm text-green-700 font-black">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Şimdi Oy Verebilirsiniz
      </div>
    {% endif %}
  </div>

  {% if voteProviders.size == 0 %}
    <div class="bg-white border border-gray-100 rounded-3xl p-12 text-center shadow-sm">
      <div class="w-16 h-16 bg-yellow-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-yellow-100 text-yellow-500">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      </div>
      <h3 class="text-xl font-black text-gray-900 mb-2">Platform Bulunamadı</h3>
      <p class="text-gray-500 font-medium">Şu anda sunucumuz için aktif bir oy verme platformu bulunmuyor. Lütfen daha sonra tekrar deneyin.</p>
    </div>
  {% else %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for provider in voteProviders %}
        {% if provider.isActive %}
          <div class="bg-white border-2 border-blue-50 hover:border-blue-200 rounded-3xl p-6 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col items-center group">
            
            {% if provider.logo %}
              <img src="{{ provider.logo }}" alt="{{ provider.type }}" class="w-16 h-16 rounded-2xl mb-4 shadow-sm object-contain bg-white">
            {% elsif provider.type == 'serversmc' %}
              <img src="/images/vote-providers/smc.webp" alt="ServersMC" class="w-16 h-16 rounded-2xl mb-4 shadow-sm object-contain bg-white">
            {% else %}
              <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-2xl flex items-center justify-center mb-4 shadow-sm border border-blue-100 group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
            {% endif %}

            <h3 class="text-xl font-black text-gray-900 mb-2 capitalize">
              {% if provider.type == 'serversmc' %}ServersMC{% else %}{{ provider.type }}{% endif %}
            </h3>
            
            <p class="text-sm font-medium text-gray-500 text-center mb-6">
              Bu platform üzerinden sunucumuza oy verebilirsiniz.
            </p>

            <a href="/vote/{{ provider.id }}" class="vote-btn w-full block text-center px-6 py-4 bg-gray-100 text-gray-900 font-black rounded-2xl transition-all shadow-sm group-hover:bg-blue-600 group-hover:text-white group-hover:shadow-blue-500/30">
              Devam Et
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Check global canVote logic and update buttons if wait time is active
    {% if customer.nextVoteAt %}
      const nextVote = new Date('{{ customer.nextVoteAt }}');
      if (nextVote > new Date()) {
        document.querySelectorAll('.vote-btn').forEach(btn => {
          btn.href = 'javascript:void(0)';
          btn.classList.add('opacity-50', 'cursor-not-allowed');
          btn.classList.remove('group-hover:bg-blue-600', 'group-hover:text-white', 'hover:shadow-xl');
          btn.innerHTML = `
            <span class="flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Bekleme Süresinde
            </span>
          `;
        });
      }
    {% endif %}
  });
</script>
