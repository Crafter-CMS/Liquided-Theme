<div class="container max-w-[1400px] mx-auto px-4 mt-8 mb-24 space-y-8">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm font-bold text-gray-500 bg-white py-3 px-6 rounded-2xl w-fit shadow-sm border border-gray-100">
    <a href="/" class="hover:text-primary transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
    </a>
    <span>/</span>
    <span class="text-gray-900">Forum</span>
  </div>

  <!-- Header -->
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-black text-gray-900 tracking-tight">Forum</h1>
      <p class="text-gray-500 mt-2">Topluluğumuzla etkileşime geçin, sorular sorun ve tartışmalara katılın.</p>
    </div>

    {% if customer %}
      <a
        href="/forum/new"
        class="bg-primary text-white font-bold rounded-xl px-6 py-3 hover:brightness-110 transition-all shadow-md shadow-primary/30 flex items-center gap-2"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Yeni Konu
      </a>
    {% endif %}
  </div>

  <!-- Main Layout -->
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8">
    <!-- Ana İçerik -->
    <div class="space-y-8">
      <!-- Kategoriler -->
      <div>
        <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
          </svg>
          Kategoriler
        </h2>

        {% if forumCategories and forumCategories.size > 0 %}
          <div class="grid gap-4 sm:grid-cols-2">
            {% for category in forumCategories %}
              <a
                href="/forum/{{ category.slug | default: category.id }}"
                class="bg-white border border-gray-100 rounded-2xl p-5 hover:shadow-md hover:border-primary/30 transition-all group flex items-start gap-4"
              >
                <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                  {% if category.icon %}
                    <i class="{{ category.icon }} text-xl"></i>
                  {% else %}
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
                    </svg>
                  {% endif %}
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 group-hover:text-primary transition-colors text-lg">
                    {{ category.name }}
                  </h3>
                  <p class="text-sm text-gray-500 mt-1 line-clamp-2">{{ category.description }}</p>
                  <div class="flex items-center gap-4 mt-3 text-xs font-semibold text-gray-400">
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                      </svg>
                      {{ category.topics.size | default: 0 }} Konu
                    </span>
                  </div>
                </div>
              </a>
            {% endfor %}
          </div>
        {% else %}
          <div class="bg-gray-50 border border-gray-100 rounded-2xl p-8 text-center">
            <p class="text-gray-500 font-medium">Henüz kategori bulunmuyor.</p>
          </div>
        {% endif %}
      </div>

      <!-- Son Konular -->
      <div>
        <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/>
          </svg>
          Son Konular
        </h2>

        {% if forumStatistics.lastTopics and forumStatistics.lastTopics.size > 0 %}
          <div class="space-y-3">
            {% for topic in forumStatistics.lastTopics %}
              {% assign catSlug = topic.categoryId | default: 't' %}
              <a
                href="/forum/{{ catSlug }}/{{ topic.slug | default: topic.id }}"
                class="block bg-white border border-gray-100 rounded-2xl p-4 hover:shadow-sm hover:border-gray-200 transition-all group"
              >
                <div class="flex items-start gap-4">
                  <div class="flex-shrink-0">
                    <img
                      src="https://mc-heads.net/avatar/{{ topic.authorName }}/40"
                      class="w-10 h-10 rounded-xl"
                      alt="{{ topic.authorName }}"
                    >
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      {% if topic.isPinned %}
                        <span class="px-2 py-0.5 bg-yellow-50 text-yellow-700 text-[10px] font-bold rounded-md uppercase tracking-wider border border-yellow-200"
                          >Sabit</span
                        >
                      {% endif %}
                      {% if topic.isLocked %}
                        <span class="px-2 py-0.5 bg-red-50 text-red-700 text-[10px] font-bold rounded-md uppercase tracking-wider border border-red-200"
                          >Kilitli</span
                        >
                      {% endif %}
                      <h3 class="font-bold text-gray-900 group-hover:text-primary truncate text-base">
                        {{ topic.title }}
                      </h3>
                    </div>
                    <div class="flex items-center gap-3 text-xs font-semibold text-gray-400">
                      <span class="text-gray-600">{{ topic.authorName }}</span>
                      <span>•</span>
                      <span>{{ topic.createdAt | date: '%d.%m.%Y %H:%M' }}</span>
                      <span>•</span>
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                        {{ topic.viewCount | default: 0 }}
                      </span>
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                        </svg>
                        {{ topic.replyCount | default: 0 }}
                      </span>
                    </div>
                  </div>
                </div>
              </a>
            {% endfor %}
          </div>
        {% else %}
          <div class="bg-gray-50 border border-gray-100 rounded-2xl p-8 text-center">
            <p class="text-gray-500 font-medium">Henüz konu bulunmuyor.</p>
          </div>
        {% endif %}
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-6">
      {% unless customer %}
        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6 text-center">
          <div class="w-16 h-16 bg-primary/10 text-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Aramıza Katılın</h3>
          <p class="text-sm text-gray-500 mb-4">Konu açmak ve cevap yazmak için giriş yapmalısınız.</p>
          <a
            href="/auth/sign-in"
            class="block w-full bg-primary text-white font-bold rounded-xl px-4 py-2 hover:brightness-110 transition-colors"
          >
            Giriş Yap
          </a>
        </div>
      {% endunless %}

      {% if forumStatistics.lastMessages and forumStatistics.lastMessages.size > 0 %}
        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-5">
          <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Son Aktiviteler
          </h3>
          <div class="space-y-4">
            {% for msg in forumStatistics.lastMessages limit: 5 %}
              <div class="flex items-start gap-3">
                <img
                  src="https://mc-heads.net/avatar/{{ msg.authorName }}/24"
                  class="w-6 h-6 rounded-md flex-shrink-0"
                  alt=""
                >
                <div class="flex-1 min-w-0">
                  <p class="text-sm text-gray-600 line-clamp-2">
                    <span class="font-bold text-gray-900">{{ msg.authorName }}</span> yanıtladı.
                  </p>
                  <p class="text-xs font-semibold text-gray-400 mt-1">{{ msg.createdAt | date: '%d.%m.%Y %H:%M' }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {% if forumStatistics.topMessageUsers and forumStatistics.topMessageUsers.size > 0 %}
        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-5">
          <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            En Aktif Kullanıcılar
          </h3>
          <div class="space-y-3">
            {% for user in forumStatistics.topMessageUsers limit: 5 %}
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="text-xs font-black text-gray-300 w-4 text-center">{{ forloop.index }}</span>
                  <img src="https://mc-heads.net/avatar/{{ user.username }}/24" class="w-6 h-6 rounded-md" alt="">
                  <span class="text-sm font-bold text-gray-700">{{ user.username }}</span>
                </div>
                <span class="text-xs font-semibold px-2 py-1 bg-gray-50 text-gray-500 rounded-md">
                  {{- user.count }} msg</span
                >
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </aside>
  </div>
</div>
