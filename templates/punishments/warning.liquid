<div class="container max-w-[1400px] mx-auto px-4 mt-8 mb-24 min-h-[50vh]">
  
  <!-- Breadcrumb -->
  <div class="flex flex-wrap items-center gap-2 text-sm font-bold text-gray-500 bg-white py-3 px-6 rounded-2xl w-fit shadow-sm border border-gray-100 mb-8">
    <a href="/" class="hover:text-primary transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
    </a>
    <span>/</span>
    <a href="/punishments" class="hover:text-primary transition-colors">Cezalar</a>
    <span>/</span>
    <span class="text-gray-900">Uyarılar</span>
  </div>

  <!-- Başlık -->
  <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div>
      <div class="flex items-center gap-3 mb-3">
        <div class="w-12 h-12 bg-yellow-50 rounded-xl flex items-center justify-center text-yellow-500 border border-yellow-100 shadow-sm">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        </div>
        <h1 class="text-3xl md:text-4xl font-black text-gray-900 tracking-tight">Uyarılar</h1>
      </div>
      <p class="text-gray-500 font-medium max-w-lg leading-relaxed">
        Sunucu kurallarını ihlal ettiği için uyarı alan oyuncuların kayıtlarını görüntüleyin.
      </p>
    </div>
    
    <!-- Arama Kutusu -->
    <div class="relative w-full md:w-80">
      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </div>
      <input type="text" id="search-input" placeholder="Oyuncu adı ara..." class="w-full pl-11 pr-4 py-3 bg-white border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-medium text-gray-900 shadow-sm">
    </div>
  </div>

  <!-- Cezalar Listesi -->
  <div class="bg-white rounded-3xl p-6 md:p-8 border border-gray-100 shadow-sm">
    <div id="punishments-list" class="space-y-4">
      <div class="py-12 text-center text-gray-400 font-bold flex flex-col items-center justify-center">
        <svg class="w-8 h-8 animate-spin mb-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        Kayıtlar Yükleniyor...
      </div>
    </div>
    
    <!-- Pagination -->
    <div id="pagination-controls" class="hidden mt-8 pt-6 border-t border-gray-100 flex items-center justify-between">
      <div class="text-sm font-bold text-gray-500" id="page-info"></div>
      <div class="flex items-center gap-2">
        <button id="prev-page" class="w-10 h-10 rounded-xl bg-gray-50 border border-gray-200 text-gray-600 hover:text-primary hover:border-primary/50 flex items-center justify-center transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          &larr;
        </button>
        <button id="next-page" class="w-10 h-10 rounded-xl bg-gray-50 border border-gray-200 text-gray-600 hover:text-primary hover:border-primary/50 flex items-center justify-center transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          &rarr;
        </button>
      </div>
    </div>
  </div>

</div>

<!-- Context'ten Gelen Veriyi JS'e Aktar -->
<script>
  window.SERVER_PUNISHMENTS_DATA = {{ punishments | json }};
</script>

<!-- Vanilla JS Data Fetching -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const listContainer = document.getElementById('punishments-list');
    const searchInput = document.getElementById('search-input');
    const paginationControls = document.getElementById('pagination-controls');
    const prevBtn = document.getElementById('prev-page');
    const nextBtn = document.getElementById('next-page');
    const pageInfo = document.getElementById('page-info');

    let allData = [];
    let filteredData = [];
    let currentPage = 1;
    const itemsPerPage = 10;

    function formatTimeAgo(dateStr) {
      const date = new Date(dateStr);
      const now = new Date();
      const seconds = Math.floor((now - date) / 1000);
      let interval = seconds / 31536000;
      if (interval > 1) return Math.floor(interval) + ' yıl önce';
      interval = seconds / 2592000;
      if (interval > 1) return Math.floor(interval) + ' ay önce';
      interval = seconds / 86400;
      if (interval > 1) return Math.floor(interval) + ' gün önce';
      interval = seconds / 3600;
      if (interval > 1) return Math.floor(interval) + ' saat önce';
      interval = seconds / 60;
      if (interval > 1) return Math.floor(interval) + ' dakika önce';
      return Math.floor(seconds) + ' saniye önce';
    }
    
    function formatDuration(start, end) {
      if (end === '-1' || !end) return 'Kalıcı';
      const startDate = new Date(start);
      const endDate = new Date(end);
      const diffMs = endDate - startDate;
      if (diffMs <= 0) return 'Süresi Doldu';
      const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diffMs % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
      if (days > 0) return days + ' gün';
      if (hours > 0) return hours + ' saat';
      return minutes + ' dakika';
    }

    function renderList() {
      const startIndex = (currentPage - 1) * itemsPerPage;
      const paginatedItems = filteredData.slice(startIndex, startIndex + itemsPerPage);
      
      if (filteredData.length === 0) {
        listContainer.innerHTML = `
          <div class="py-12 text-center text-gray-500 font-bold bg-gray-50 rounded-2xl border border-gray-100 border-dashed">
            Henüz bu kategoride bir ceza bulunmuyor.
          </div>
        `;
        paginationControls.classList.add('hidden');
        return;
      }

      listContainer.innerHTML = '';
      paginatedItems.forEach(p => {
        const html = \`
          <div class="flex flex-col sm:flex-row justify-between p-5 bg-gray-50 rounded-2xl border border-gray-100 hover:border-yellow-200 hover:shadow-sm transition-all gap-4">
            <div class="flex gap-4">
              <div class="w-14 h-14 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden shrink-0 mt-1">
                <img src="https://mc-heads.net/avatar/\${p.name}/56" alt="\${p.name}" class="w-full h-full object-cover">
              </div>
              <div>
                <div class="flex items-center gap-3 mb-1">
                  <h4 class="font-black text-lg text-gray-900">\${p.name}</h4>
                  <span class="px-2.5 py-0.5 rounded-md text-[10px] font-black border bg-yellow-100 text-yellow-600 border-yellow-200 uppercase tracking-wider">\${p.punishmentType.replace('_', ' ')}</span>
                </div>
                <p class="text-sm font-medium text-gray-600 mb-2">\${p.reason || 'Sebep belirtilmedi'}</p>
                
                <div class="flex flex-wrap items-center gap-4 text-xs font-bold text-gray-400">
                  <div class="flex items-center gap-1.5" title="Yetkili"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>\${p.operator || 'Konsol'}</div>
                  <div class="flex items-center gap-1.5" title="Tarih"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>\${formatTimeAgo(p.start)}</div>
                  <div class="flex items-center gap-1.5 text-gray-500" title="Süre"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>\${formatDuration(p.start, p.end)}</div>
                </div>
              </div>
            </div>
          </div>
        \`;
        listContainer.insertAdjacentHTML('beforeend', html);
      });

      // Pagination UI Update
      paginationControls.classList.remove('hidden');
      const totalPages = Math.ceil(filteredData.length / itemsPerPage);
      pageInfo.textContent = \`\${filteredData.length} kayıttan \${startIndex + 1} - \${Math.min(startIndex + itemsPerPage, filteredData.length)} gösteriliyor\`;
      
      prevBtn.disabled = currentPage === 1;
      nextBtn.disabled = currentPage >= totalPages;
    }

    try {
      const data = window.SERVER_PUNISHMENTS_DATA || {};
      
      if (data.statusCode === 400) {
        listContainer.innerHTML = \`
          <div class="py-12 text-center text-gray-500 font-bold bg-gray-50 rounded-2xl border border-gray-100 border-dashed">
            Cezalar modülü şu anda aktif değil.
          </div>
        \`;
        return;
      }

      const punishments = data.punishments || data.data?.punishments || data.data || [];
      // Sadece WARNING türlerini filtrele
      allData = punishments.filter(p => p.punishmentType === 'WARNING' || p.punishmentType === 'TEMP_WARNING');
      filteredData = [...allData];
      
      renderList();
    } catch (err) {
      listContainer.innerHTML = \`
        <div class="py-12 text-center text-red-500 font-bold bg-red-50 rounded-2xl border border-red-100">
          Kayıtlar yüklenirken bir hata oluştu.
        </div>
      \`;
    }

    // Arama Eventi
    searchInput.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase();
      filteredData = allData.filter(p => p.name.toLowerCase().includes(q));
      currentPage = 1;
      renderList();
    });

    // Sayfalama Eventleri
    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        renderList();
      }
    });
    
    nextBtn.addEventListener('click', () => {
      const totalPages = Math.ceil(filteredData.length / itemsPerPage);
      if (currentPage < totalPages) {
        currentPage++;
        renderList();
      }
    });
  });
</script>
