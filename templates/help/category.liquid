<div class="container max-w-[1400px] mx-auto px-4 mt-8 mb-24 space-y-8 min-h-[50vh]">
  <!-- Breadcrumb -->
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex flex-wrap items-center gap-2 text-sm font-bold text-gray-500 bg-white py-3 px-6 rounded-2xl w-fit shadow-sm border border-gray-100">
      <a href="/help" class="hover:text-primary transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>
      <span>/</span>
      <a href="/help" class="hover:text-primary transition-colors">Yardım Merkezi</a>
      <span>/</span>
      <span class="text-gray-900">{{ categoryDetail.name | default: 'Kategori' }}</span>
    </div>
    <a href="/help" class="flex items-center gap-2 text-sm font-bold text-gray-500 hover:text-gray-900 bg-white hover:bg-gray-50 py-3 px-6 rounded-2xl transition-colors border border-gray-100 shadow-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Geri Dön
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[380px_1fr] gap-8">
    
    <!-- Sol: Makale Listesi (Sidebar) -->
    <div class="space-y-6">
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sticky top-24">
        <div class="flex items-center gap-4 mb-6 pb-6 border-b border-gray-100">
          <div class="w-14 h-14 bg-primary/10 text-primary rounded-2xl flex items-center justify-center flex-shrink-0">
            {% if categoryDetail.icon == 'CubeIcon' %}
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            {% elsif categoryDetail.icon == 'DiscordIcon' %}
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
            {% else %}
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {% endif %}
          </div>
          <div>
            <h1 class="text-lg font-black text-gray-900 leading-tight">{{ categoryDetail.name }}</h1>
            <p class="text-xs text-gray-500 font-medium mt-1 line-clamp-2">{{ categoryDetail.description }}</p>
          </div>
        </div>

        <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4">İçerikler ({{ categoryDetail.items.size | default: 0 }})</h3>
        
        <div class="space-y-2 flex flex-col" id="article-list">
          {% for item in categoryDetail.items %}
            <button
              onclick="showArticle('{{ item.id }}')"
              class="article-btn w-full text-left p-4 rounded-2xl flex items-center gap-3 transition-all border border-transparent font-medium
              {% if forloop.first %} bg-primary text-white shadow-md shadow-primary/20 {% else %} text-gray-600 hover:bg-gray-50 hover:text-gray-900 border-gray-100/50 hover:border-gray-200 {% endif %}"
              data-id="{{ item.id }}"
            >
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors
              {% if forloop.first %} bg-white/20 {% else %} bg-gray-100 text-gray-400 {% endif %}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <span class="truncate">{{ item.title }}</span>
            </button>
          {% else %}
            <div class="p-4 text-center text-sm text-gray-500 bg-gray-50 rounded-2xl">
              Bu kategoride içerik bulunmuyor.
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Sağ: Makale İçeriği -->
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden min-h-[500px]">
      <div id="articles-container">
        {% for item in categoryDetail.items %}
          <div id="article-{{ item.id }}" class="article-content {% unless forloop.first %}hidden{% endunless %}">
            <div class="p-8 md:p-10 border-b border-gray-50 bg-gray-50/30 flex items-center gap-4">
              <h2 class="text-2xl md:text-3xl font-black text-gray-900 tracking-tight">{{ item.title }}</h2>
            </div>
            <div class="p-8 md:p-10 prose prose-lg max-w-none text-gray-600 font-medium leading-relaxed prose-headings:text-gray-900 prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-p:mb-4">
              {% if item.content.root.children %}
                {% for node in item.content.root.children %}
                  {% if node.type == 'paragraph' %}
                    <p>{{ node.children[0].text }}</p>
                  {% elsif node.type == 'heading' %}
                    <h3 class="text-xl font-bold mt-6 mb-3">{{ node.children[0].text }}</h3>
                  {% else %}
                    <div>{{ node.children[0].text }}</div>
                  {% endif %}
                {% endfor %}
              {% else %}
                <p>Bu makale için içerik bulunamadı.</p>
              {% endif %}
            </div>
          </div>
        {% else %}
          <div class="p-16 text-center h-full flex flex-col items-center justify-center">
            <div class="w-24 h-24 bg-gray-50 rounded-3xl flex items-center justify-center text-gray-300 mb-6">
              <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <h3 class="text-2xl font-black text-gray-900 mb-2">Makale Seçin</h3>
            <p class="text-gray-500 font-medium max-w-md mx-auto">
              Okumak istediğiniz içeriği sol menüden seçebilirsiniz. Seçtiğiniz makalenin detayı burada görüntülenecektir.
            </p>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
  function showArticle(articleId) {
    // Tüm makaleleri gizle
    document.querySelectorAll('.article-content').forEach(el => {
      el.classList.add('hidden');
    });
    
    // Sadece tıklananı göster
    const selectedArticle = document.getElementById('article-' + articleId);
    if (selectedArticle) {
      selectedArticle.classList.remove('hidden');
    }

    // Buton stillerini güncelle
    document.querySelectorAll('.article-btn').forEach(btn => {
      const isSelected = btn.getAttribute('data-id') === articleId;
      const iconWrap = btn.querySelector('div');
      
      if (isSelected) {
        btn.className = 'article-btn w-full text-left p-4 rounded-2xl flex items-center gap-3 transition-all border border-transparent font-medium bg-primary text-white shadow-md shadow-primary/20';
        iconWrap.className = 'w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors bg-white/20';
      } else {
        btn.className = 'article-btn w-full text-left p-4 rounded-2xl flex items-center gap-3 transition-all border border-gray-100/50 hover:border-gray-200 font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900';
        iconWrap.className = 'w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 transition-colors bg-gray-100 text-gray-400';
      }
    });
  }
</script>
