<div class="container max-w-[1400px] mx-auto px-4 mt-8 mb-24 space-y-8 min-h-[60vh]">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm font-bold text-gray-500 bg-white py-3 px-6 rounded-2xl w-fit shadow-sm border border-gray-100">
    <a href="/" class="hover:text-primary transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
    </a>
    <span>/</span>
    <a href="/vote" class="hover:text-gray-900 transition-colors">Oy Ver</a>
    <span class="text-gray-900 capitalize">
      {% if provider.type == 'serversmc' %}ServersMC{% else %}{{ provider.type }}{% endif %}
    </span>
  </div>

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-black text-gray-900 tracking-tight">
      {% if provider.type == 'serversmc' %}ServersMC{% else %}<span class="capitalize">{{ provider.type }}</span>{% endif %}
    </h1>
    <p class="text-gray-500 mt-2">Bu platform üzerinden sunucumuza oy verebilirsiniz.</p>
  </div>

  <div class="max-w-3xl">
      <div class="bg-white border border-gray-100 rounded-3xl p-6 md:p-10 shadow-sm relative overflow-hidden">
        
        <div class="flex items-center gap-6 mb-8">
          {% if provider.logo %}
            <img src="{{ provider.logo }}" alt="{{ provider.type }}" class="w-16 h-16 rounded-2xl shadow-sm object-contain bg-white">
          {% elsif provider.type == 'serversmc' %}
            <img src="/images/vote-providers/smc.webp" alt="ServersMC" class="w-16 h-16 rounded-2xl shadow-sm object-contain bg-white">
          {% else %}
            <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-2xl flex items-center justify-center shadow-sm border border-blue-100">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
          {% endif %}
          
          <div>
            <h2 class="text-xl font-black text-gray-900">Oy Verme İşlemi</h2>
            <p class="text-gray-500 font-medium">Lütfen bekleme süresine dikkat ederek oy gönder butonuna tıklayın.</p>
          </div>
        </div>
      <div id="vote-status-container"></div>

      <!-- Success Message -->
      <div
        id="vote-success"
        class="hidden mb-8 p-6 rounded-2xl bg-green-50 border border-green-100 flex items-start gap-4 animate-[fade-in-up_0.3s_ease-out]"
      >
        <div class="w-12 h-12 rounded-xl bg-green-100 text-green-600 flex items-center justify-center shrink-0">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <div>
          <h4 class="text-lg font-black text-green-900 mb-1">Oy Gönderildi!</h4>
          <p id="vote-success-text" class="text-green-700 font-medium">
            Oyunuz başarıyla kaydedildi. Bizi desteklediğiniz için teşekkür ederiz!
          </p>
        </div>
      </div>

      <!-- Error Message -->
      <div id="vote-error" class="hidden mb-8 p-6 rounded-2xl bg-red-50 border border-red-100 flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-red-100 text-red-600 flex items-center justify-center shrink-0">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <div>
          <h4 class="text-lg font-black text-red-900 mb-1">Gönderim Başarısız</h4>
          <p id="vote-error-text" class="text-red-700 font-medium">Oy gönderilirken bir hata oluştu.</p>
        </div>
      </div>

      <div class="space-y-4">
        <button
          id="btn-submit-vote"
          class="w-full px-8 py-5 bg-blue-600 text-white font-black text-lg rounded-2xl hover:brightness-110 transition-all shadow-md shadow-blue-500/30 flex items-center justify-center gap-3"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Oy Ver & Ödülü Al
        </button>

          <a
            href="/vote"
            class="w-full flex items-center justify-center px-8 py-4 bg-gray-50 text-gray-700 font-bold rounded-2xl hover:bg-gray-100 transition-all"
          >
            Geri Dön
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btnSubmit = document.getElementById('btn-submit-vote');
    const boxSuccess = document.getElementById('vote-success');
    const boxError = document.getElementById('vote-error');
    const textSuccess = document.getElementById('vote-success-text');
    const textError = document.getElementById('vote-error-text');
    const statusContainer = document.getElementById('vote-status-container');
    const providerId = '{{ provider.id | default: provider._id }}';

    let canVote = true;

    // Check if user has a nextVoteAt
    {% if customer.nextVoteAt %}
      const nextVote = new Date('{{ customer.nextVoteAt }}');
      if (nextVote > new Date()) {
        canVote = false;
        
        statusContainer.innerHTML = `
          <div class="mb-8 bg-yellow-50 border border-yellow-100 rounded-2xl p-4 flex flex-col items-center gap-2">
            <div class="flex items-center gap-2 text-yellow-700 font-black">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Bekleme Süresi
            </div>
            <div class="text-yellow-600 font-bold">
              Sonraki oy: ${nextVote.toLocaleString('tr-TR')}
            </div>
          </div>
        `;

        btnSubmit.disabled = true;
        btnSubmit.classList.remove('bg-blue-600', 'hover:brightness-110', 'shadow-blue-500/30');
        btnSubmit.classList.add('bg-gray-300', 'cursor-not-allowed', 'text-gray-500');
        btnSubmit.innerHTML = `
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Şu an oy veremezsiniz
        `;
      } else {
        statusContainer.innerHTML = `
          <div class="mb-8 bg-green-50 border border-green-100 rounded-2xl p-4 flex items-center justify-center gap-2 text-green-700 font-black">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Şimdi Oy Verebilirsiniz
          </div>
        `;
      }
    {% else %}
      statusContainer.innerHTML = `
        <div class="mb-8 bg-green-50 border border-green-100 rounded-2xl p-4 flex items-center justify-center gap-2 text-green-700 font-black">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Şimdi Oy Verebilirsiniz
        </div>
      `;
    {% endif %}

    btnSubmit.addEventListener('click', async () => {
      if (!canVote) return;

      boxError.classList.add('hidden');
      boxSuccess.classList.add('hidden');
      
      btnSubmit.disabled = true;
      btnSubmit.innerHTML = `
        <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        İşleniyor...
      `;

      try {
        const res = await fetch('/api/storefront/config/vote-providers/vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ providerId })
        });
        
        const data = await res.json();
        
        if (res.ok && !data.error && data.status !== false) {
          boxSuccess.classList.remove('hidden');
          if (data.message) {
            textSuccess.innerText = data.message;
          }
          // Redirect to the URL or reload after 2s
          setTimeout(() => {
            window.location.reload();
          }, 2000);
        } else {
          boxError.classList.remove('hidden');
          textError.innerText = data.message || data.error || 'Oy gönderilirken bir hata oluştu.';
          
          btnSubmit.disabled = false;
          btnSubmit.innerHTML = `
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Tekrar Dene
          `;
        }
      } catch (err) {
        boxError.classList.remove('hidden');
        textError.innerText = 'Sunucuyla bağlantı kurulamadı.';
        btnSubmit.disabled = false;
        btnSubmit.innerHTML = `
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Tekrar Dene
        `;
      }
    });
  });
</script>
