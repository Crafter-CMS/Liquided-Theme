<!-- ANA SAYFA -->
<div class="container max-w-[1400px] mx-auto px-4 mt-8">
  <!-- SLIDER ALANI -->
  {% if settings.home.slider != blank and settings.home.slider.size > 0 %}
    <div class="w-full mb-12">
      <div class="relative w-full h-[400px] rounded-3xl overflow-hidden shadow-2xl group">
        <!-- CSS-Only Slider Wrapper (Basit Örnek) -->
        <div
          class="flex w-full h-full transition-transform duration-500"
          style="width: {{ settings.home.slider.size | times: 100 }}%;"
        >
          {% for slide in settings.home.slider %}
            <div class="relative w-full h-full flex-shrink-0">
              <img
                src="{% if slide.image %}{{ slide.image }}{% else %}https://images.unsplash.com/photo-1607513746994-51f730a44832?q=80&w=2000&auto=format&fit=crop{% endif %}"
                class="w-full h-full object-cover"
                alt="{{ slide.title }}"
              >
              <div class="absolute inset-0 bg-gradient-to-r from-gray-900/80 via-gray-900/40 to-transparent"></div>

              <div class="absolute inset-0 flex flex-col justify-center px-12 md:px-24">
                <h2 class="text-4xl md:text-5xl font-black text-white mb-4 drop-shadow-lg tracking-tight">
                  {{ slide.title | default: 'Maceraya Hazır Mısın?' }}
                </h2>
                <p class="text-lg md:text-xl text-gray-200 mb-8 max-w-2xl font-medium drop-shadow">
                  {{
                    slide.description
                    | default: 'Sunucumuzdaki en yeni güncellemeleri keşfet ve hemen aramıza katıl.'
                  }}
                </p>
                {% if slide.button_text != blank %}
                  <a
                    href="{{ slide.button_url }}"
                    class="w-fit bg-primary hover:bg-blue-600 text-white font-bold py-4 px-8 rounded-xl transition-all hover:scale-105 hover:shadow-lg shadow-primary/30 flex items-center gap-2"
                  >
                    {{ slide.button_text }}
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                    </svg>
                  </a>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  <!-- İKİLİ SÜTUN (Sol: Haberler, Sağ: Discord & İstatistik) -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
    <!-- SOL: SON GÖNDERİLER -->
    <div class="lg:col-span-2 space-y-6">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-2xl font-black text-gray-900 tracking-tight flex items-center gap-3">
          <span class="w-2 h-8 bg-primary rounded-full"></span>
          Son Gönderiler & Duyurular
        </h3>
        <a
          href="/posts"
          class="text-sm font-bold text-primary hover:text-blue-700 transition-colors flex items-center gap-1"
          >Tümünü Gör
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- CMS'den gelen gönderileri (posts) döndürüyoruz -->
        {% if posts.size > 0 %}
          {% for post in posts limit: 4 %}
            <a
              href="/posts/{{ post.slug }}"
              class="group bg-white border border-gray-100 rounded-3xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full"
            >
              <div class="h-48 overflow-hidden relative">
                <img
                  src="{% if post.featuredImage != blank %}{{ post.featuredImage }}{% else %}https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=2070&auto=format&fit=crop{% endif %}"
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  alt="{{ post.title }}"
                >
                <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-black text-gray-800 shadow-sm uppercase tracking-wider">
                  {% if post.type == 'update' -%}
                    Güncelleme
                  {% elsif post.type == 'announcement' -%}
                    Duyuru
                  {% elsif post.type == 'news' -%}
                    Haber
                  {% elsif post.type == 'blog' -%}
                    Blog
                  {% else -%}
                    {{- post.type -}}
                  {%- endif %}
                </div>
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <div class="text-xs font-bold text-gray-400 mb-2">
                  {{ post.createdAt | date: '%d.%m.%Y' }} &bull;
                  {{ post.author.username | default: post.authorName | default: 'Yönetim' }}
                </div>
                <h4 class="text-lg font-bold text-gray-900 leading-tight mb-3 group-hover:text-primary transition-colors">
                  {{ post.title }}
                </h4>
                <p class="text-sm text-gray-600 line-clamp-2 mt-auto">
                  {% if post.metaDescription != blank %}
                    {{ post.metaDescription }}
                  {% else %}
                    {{
                      post.content
                      | lexical_text
                      | truncate: 120
                      | default: 'İçeriğin devamını okumak için tıklayın...'
                    }}
                  {% endif %}
                </p>

                <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between text-xs font-bold text-gray-400">
                  <div class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                    <span>{{ post.viewCount | default: 0 }}</span>
                  </div>
                  <div class="flex items-center gap-1.5 text-primary">
                    <span>Devamını Oku</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                    <span>{{ post.likeCount | default: 0 }}</span>
                  </div>
                </div>
              </div>
            </a>
          {% endfor %}
        {% else %}
          <div class="col-span-1 sm:col-span-2 py-12 text-center text-gray-500 font-medium bg-gray-50 rounded-3xl border border-dashed border-gray-200">
            Henüz hiç gönderi bulunmuyor.
          </div>
        {% endif %}
      </div>
    </div>

    <!-- SAĞ: DISCORD & İSTATİSTİKLER -->
    <div class="space-y-6">
      <!-- Son Satın Alımlar -->
      <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm">
        <h3 class="text-lg font-black text-gray-900 tracking-tight mb-5 flex items-center gap-2">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          Son Satın Alımlar
        </h3>

        <div class="flex flex-col gap-3">
          {% if stats.latest.purchases.size > 0 %}
            {% for purchase in stats.latest.purchases limit: 3 %}
              <div class="flex items-center gap-4 p-3 bg-gray-50 rounded-2xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-gray-200 transition-all group">
                <img
                  src="https://mc-heads.net/avatar/{{ purchase.username }}/100"
                  alt="{{ purchase.username }}"
                  class="w-12 h-12 rounded-xl shadow-sm bg-gray-200 group-hover:scale-105 transition-transform"
                >
                <div class="flex-grow min-w-0">
                  <div class="font-bold text-gray-900 truncate">{{ purchase.username }}</div>
                  <div class="text-xs text-gray-500 truncate">{{ purchase.productName }}</div>
                </div>
                <div class="font-black text-green-600 shrink-0">₺{{ purchase.amount }}</div>
              </div>
            {% endfor %}
          {% else %}
            <div class="text-sm text-gray-500 text-center py-4 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
              Henüz satın alım bulunmuyor.
            </div>
          {% endif %}
        </div>
      </div>
      <!-- En Çok Kredi Yükleyenler -->
      <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm">
        <h3 class="text-lg font-black text-gray-900 tracking-tight mb-5 flex items-center gap-2">
          <svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
          </svg>
          En Çok Kredi Yükleyenler
        </h3>

        <div class="flex flex-col gap-3">
          {% if stats.topCreditLoaders.size > 0 %}
            {% for loader in stats.topCreditLoaders limit: 3 %}
              <div class="flex items-center gap-4 p-3 bg-gray-50 rounded-2xl border border-gray-100 hover:bg-white hover:shadow-md hover:border-gray-200 transition-all relative overflow-hidden group">
                {% if forloop.index == 1 %}
                  <div class="absolute -right-3 -top-3 w-12 h-12 bg-yellow-400 rounded-full flex items-end justify-start p-2 text-white font-black text-xs shadow-lg transform rotate-12 z-10">
                    #1
                  </div>
                {% endif %}
                <img
                  src="https://mc-heads.net/avatar/{{ loader.username }}/100"
                  alt="{{ loader.username }}"
                  class="w-12 h-12 rounded-xl shadow-sm bg-gray-200 relative z-20 group-hover:scale-105 transition-transform"
                >
                <div class="flex-grow min-w-0 relative z-20">
                  <div class="font-bold text-gray-900 truncate">{{ loader.username }}</div>
                  <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest truncate">Destekçi</div>
                </div>
                <div class="font-black text-primary shrink-0 pr-2 relative z-20">{{ loader.totalAmount }} ₺</div>
              </div>
            {% endfor %}
          {% else %}
            <div class="text-sm text-gray-500 text-center py-4 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
              Henüz veri bulunmuyor.
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Discord Widget -->
      {% assign discord_id = settings.discord.guild_id | default: '1256991995147190272' %}
      <div class="bg-white border border-gray-100 rounded-3xl overflow-hidden shadow-sm">
        <iframe
          src="https://discord.com/widget?id={{ discord_id }}&theme=light"
          width="100%"
          height="400"
          allowtransparency="true"
          frameborder="0"
          sandbox="allow-popups allow-popups-to-escape-sandbox allow-same-origin allow-scripts"
        ></iframe>
      </div>
    </div>
  </div>

  <!-- ALT: ÖNE ÇIKAN ÜRÜNLER -->
  {% if category_products and category_products.size > 0 %}
    <div class="mb-20">
      <div class="flex items-center justify-between mb-8">
        <h3 class="text-2xl font-black text-gray-900 tracking-tight flex items-center gap-3">
          <span class="w-2 h-8 bg-primary rounded-full"></span>
          Öne Çıkan Ürünler
        </h3>
        <a
          href="/store"
          class="text-sm font-bold text-primary hover:text-blue-700 transition-colors flex items-center gap-1"
          >Mağazaya Git
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {% for product in category_products limit: 4 %}
          <div class="bg-white border border-gray-100 rounded-3xl p-5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col group relative overflow-hidden">
            <!-- Product Badges -->
            <div class="absolute top-4 left-4 z-10 flex flex-col gap-2">
              {% if product.discountValue and product.discountValue > 0 %}
                <span class="bg-red-500 text-white text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg w-fit">
                  -{{ product.discountValue -}}
                  {%- if product.discountType == 'percentage' %}%{% else %}₺{% endif %} İndirim
                </span>
              {% endif %}

              <!-- Stok Durumu -->
              {% if product.stock <= 0 %}
                <span class="bg-emerald-50 text-emerald-600 border border-emerald-200 text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg flex items-center gap-1.5 w-fit">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                  Sınırsız
                </span>
              {% elsif product.stock <= 10 %}
                <span class="bg-orange-50 text-orange-600 border border-orange-200 text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg flex items-center gap-1.5 w-fit">
                  <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
                  Son {{ product.stock }}
                </span>
              {% endif %}
            </div>

            <!-- Product Image Area -->
            <a
              href="/store/{{ product.serverSlug }}/{{ product.categorySlug }}/{{ product.slug }}"
              class="w-full aspect-square bg-gray-50 rounded-2xl mb-4 flex items-center justify-center border border-gray-100 overflow-hidden relative block"
            >
              {% if product.images and product.images.size > 0 %}
                <img
                  src="{{ product.images[0] }}"
                  alt="{{ product.name }}"
                  class="w-3/4 h-3/4 object-contain filter drop-shadow-xl group-hover:scale-110 transition-transform duration-500"
                >
              {% elsif product.image != blank %}
                <img
                  src="{{ product.image }}"
                  alt="{{ product.name }}"
                  class="w-3/4 h-3/4 object-contain filter drop-shadow-xl group-hover:scale-110 transition-transform duration-500"
                >
              {% else %}
                <svg
                  class="w-24 h-24 text-gray-200 group-hover:scale-110 transition-transform duration-500"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
                </svg>
              {% endif %}

              <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-4">
                <button class="bg-primary hover:bg-blue-600 text-white text-sm font-bold py-2 px-6 rounded-xl transition-colors shadow-lg shadow-primary/30">
                  İncele
                </button>
              </div>
            </a>

            <!-- Product Info -->
            <div class="text-center mt-auto">
              <a href="/store/{{ product.server_id }}/{{ product.category }}/{{ product.slug }}">
                <h4 class="text-lg font-black text-gray-900 group-hover:text-primary transition-colors line-clamp-1">
                  {{ product.name }}
                </h4>
              </a>
              <div class="flex items-center justify-center gap-2 mt-2">
                {% if product.discountValue and product.discountValue > 0 %}
                  <span class="text-gray-400 font-bold line-through text-sm">₺{{ product.price }}</span>
                  <span class="text-primary font-black text-xl">
                    {% if product.discountType == 'percentage' %}
                      ₺{{ product.price | times: product.discountValue | divided_by: 100 | minus: product.price | abs }}
                    {% else %}
                      ₺{{ product.price | minus: product.discountValue }}
                    {% endif %}
                  </span>
                {% else %}
                  <span class="text-primary font-black text-xl">₺{{ product.price }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>
