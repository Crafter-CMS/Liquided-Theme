<!-- STORE > CATEGORY — ÜRÜN LİSTESİ -->
<div class="container max-w-[1400px] mx-auto px-4 mt-8 mb-24 space-y-12">
  <!-- Breadcrumb & Geri Dön -->
  <div class="flex flex-wrap items-center gap-2 text-sm font-bold text-gray-500 bg-white py-3 px-6 rounded-2xl w-fit shadow-sm border border-gray-100">
    <a href="/store" class="hover:text-primary transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
    </a>
    <span>/</span>
    <a href="/store/{{ server.slug }}" class="hover:text-primary transition-colors">
      {{- server.name | default: 'Sunucu' -}}
    </a>
    <span>/</span>
    <span class="text-gray-900">{{ category.name | default: 'Kategori' }}</span>
  </div>

  <!-- Kategori Karşılama Banner -->
  <div class="w-full bg-white border border-gray-100 rounded-3xl p-8 md:p-12 shadow-sm relative overflow-hidden flex flex-col md:flex-row items-center gap-8">
    {% if category.image != blank %}
      <div class="shrink-0 relative z-10">
        <img
          src="{{ category.image }}"
          class="w-32 h-32 md:w-48 md:h-48 object-contain rounded-2xl shadow-sm bg-gray-50 p-4 border border-gray-100"
        >
      </div>
    {% endif %}

    <div class="flex-grow relative z-10">
      <h1 class="text-3xl md:text-5xl font-black text-gray-900 mb-3 tracking-tight">
        {{ category.name | default: 'Ürünler' }}
      </h1>
      {% if category.description != blank %}
        <p class="text-lg text-gray-500 font-medium max-w-3xl">
          {{ category.description }}
        </p>
      {% endif %}
    </div>
  </div>
  <!-- ÜRÜNLER -->
  {% if products.size > 0 %}
    <!--
      ============================================================
      LİSTE / KARŞILAŞTIRMA TABLOSU FORMATI (Beyaz Premium Tema)
      ============================================================
    -->
    {% if category.type == 'listed_products' %}
      {% if category.addons and category.addons.size > 0 %}
        <div class="overflow-x-auto w-full pb-4">
          <div style="min-width:760px">
            <!-- Ürün Kartları (Tablo Başlıkları) -->
            <div class="grid gap-4 mb-4" style="grid-template-columns: 220px repeat({{ products.size }}, 1fr)">
              <div></div>
              <!-- Sol boşluk (Özellik isimleri için) -->
              {% for product in products %}
                <div class="bg-white border border-gray-100 rounded-3xl p-5 flex flex-col items-center gap-3 text-center shadow-sm relative hover:border-gray-300 transition-colors">
                  <a
                    href="/store/{{ server.slug }}/{{ category.slug }}/{{ product.slug }}"
                    class="w-20 h-20 bg-gray-50 rounded-2xl flex items-center justify-center p-2 border border-gray-100 mb-2 group-hover:border-primary transition-colors"
                  >
                    {% if product.images and product.images.size > 0 %}
                      <img src="{{ product.images[0] }}" alt="{{ product.name }}" class="w-full h-full object-contain">
                    {% elsif product.image %}
                      <img src="{{ product.image }}" alt="{{ product.name }}" class="w-full h-full object-contain">
                    {% else %}
                      <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                      </svg>
                    {% endif %}
                  </a>

                  <a href="/store/{{ server.slug }}/{{ category.slug }}/{{ product.slug }}">
                    <h3 class="font-black text-lg text-gray-900 leading-tight hover:text-primary transition-colors">
                      {{ product.name }}
                    </h3>
                  </a>
                  <p class="text-xs text-gray-500 leading-relaxed line-clamp-3 mb-2">{{ product.description | lexical_text | truncate: 150 }}</p>

                  <div class="mt-auto mb-2 flex flex-col items-center justify-center gap-2">
                    {% if product.stock <= 0 %}
                      <span class="bg-emerald-50 text-emerald-600 border border-emerald-200 text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg"
                        >Stok Sınırsız</span
                      >
                    {% elsif product.stock <= 10 %}
                      <span class="bg-orange-50 text-orange-600 border border-orange-200 text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg animate-pulse"
                        >Son {{ product.stock }} Adet</span
                      >
                    {% else %}
                      <span class="bg-gray-50 text-gray-500 border border-gray-200 text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg"
                        >Stok: {{ product.stock -}}
                      </span>
                    {% endif %}

                    <div class="flex items-center gap-2 mt-1">
                      {% if product.discountValue and product.discountValue > 0 %}
                        <div class="bg-red-500 text-white text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg shadow-sm">
                          -{{ product.discountValue -}}
                          {%- if product.discountType == 'percentage' %}%{% else %}₺{% endif %} İndirim
                        </div>
                      {% endif %}
                      <div class="text-2xl font-black text-primary">{{ product.price }} ₺</div>
                    </div>
                  </div>

                  <button
                    data-product="{{ product | json | escape }}"
                    onclick="window.addToCart(JSON.parse(this.dataset.product))"
                    class="w-full justify-center text-sm font-bold py-2 px-4 rounded-xl transition-colors shadow-sm flex items-center gap-2 bg-gray-100 text-gray-700 hover:bg-gray-200"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    Sepete Ekle
                  </button>
                </div>
              {% endfor %}
            </div>

            <!-- Özellikler Tablosu (Beyaz Tema) -->
            <div class="bg-white border border-gray-100 rounded-3xl overflow-hidden shadow-sm">
              {% for addon in category.addons %}
                <div>
                  <!-- Bölüm Başlığı -->
                  <div class="px-6 py-3 bg-gray-50 border-b border-gray-100">
                    <h4 class="font-black text-xs uppercase tracking-widest text-gray-500">{{ addon.title }}</h4>
                  </div>

                  {% for feature in addon.features %}
                    <div
                      class="grid hover:bg-gray-50/50 transition-colors border-b border-gray-100 last:border-b-0"
                      style="grid-template-columns: 220px repeat({{ products.size }}, 1fr);"
                    >
                      <!-- Özellik Adı -->
                      <div class="px-6 py-4 flex items-center gap-2 group relative border-r border-gray-100">
                        <span class="text-sm font-bold text-gray-700">{{ feature.title }}</span>
                        {% if feature.info %}
                          <div class="relative">
                            <svg
                              class="w-4 h-4 cursor-pointer text-gray-400 hover:text-primary transition-colors"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <!-- Tooltip -->
                            <div class="absolute left-full ml-2 top-1/2 -translate-y-1/2 w-56 p-3 rounded-xl text-xs leading-relaxed opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 shadow-xl bg-gray-900 text-white font-medium">
                              {{ feature.info }}
                            </div>
                          </div>
                        {% endif %}
                      </div>

                      <!-- Ürün Değerleri -->
                      {% for product in products %}
                        {% assign found_addon = null %}
                        {% assign found_feature = null %}
                        {% for pa in product.selectedAddons %}
                          {% if pa.addonId == addon.id %}{% assign found_addon = pa %}{% endif %}
                        {% endfor %}
                        {% if found_addon %}
                          {% for pf in found_addon.features %}
                            {% if pf.featureId == feature.id %}{% assign found_feature = pf %}{% endif %}
                          {% endfor %}
                        {% endif %}

                        <div class="px-5 py-4 flex items-center justify-center border-r border-gray-50 last:border-r-0">
                          {% if found_feature and found_feature.included %}
                            {% if found_feature.customValue and found_feature.customValue != '' %}
                              <span class="text-sm font-black text-primary px-3 py-1 rounded-lg bg-blue-50">
                                {{ found_feature.customValue }}
                              </span>
                            {% else %}
                              <div class="w-8 h-8 rounded-full bg-green-50 flex items-center justify-center text-green-500">
                                <svg
                                  class="w-5 h-5"
                                  fill="none"
                                  stroke="currentColor"
                                  viewBox="0 0 24 24"
                                  stroke-width="3"
                                >
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                                </svg>
                              </div>
                            {% endif %}
                          {% else %}
                            <div class="w-8 h-8 rounded-full flex items-center justify-center text-gray-300">
                              <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-width="2.5"
                              >
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                              </svg>
                            </div>
                          {% endif %}
                        </div>
                      {% endfor %}
                    </div>
                  {% endfor %}
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}

      <!--
        ============================================================
        GRID FORMAT (Standart Kartlar - Beyaz Tema)
        ============================================================
      -->
    {% else %}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {% for product in products %}
          <div class="bg-white border border-gray-100 rounded-3xl p-5 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col group relative overflow-hidden">
            <div class="absolute top-4 left-4 z-10 flex flex-col gap-2 items-start">
              {% if product.discountValue and product.discountValue > 0 %}
                <span class="bg-red-500 text-white text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg shadow-sm w-fit">
                  -{{ product.discountValue -}}
                  {%- if product.discountType == 'percentage' %}%{% else %}₺{% endif %} İndirim
                </span>
              {% endif %}

              {% if product.stock <= 0 %}
                <span class="bg-emerald-500 text-white text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg shadow-sm w-fit"
                  >Stok Sınırsız</span
                >
              {% elsif product.stock <= 10 %}
                <span class="bg-orange-500 text-white text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg shadow-sm w-fit animate-pulse"
                  >Son {{ product.stock }} Adet!</span
                >
              {% else %}
                <span class="bg-gray-800 text-white text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-lg shadow-sm w-fit"
                  >Stok: {{ product.stock -}}
                </span>
              {% endif %}
            </div>

            <a
              href="/store/{{ server.slug }}/{{ category.slug }}/{{ product.slug }}"
              class="w-full aspect-square bg-gray-50 rounded-2xl mb-4 flex items-center justify-center border border-gray-100 overflow-hidden relative block"
            >
              {% if product.images and product.images.size > 0 %}
                <img
                  src="{{ product.images[0] }}"
                  class="w-3/4 h-3/4 object-contain group-hover:scale-110 transition-transform duration-500"
                  alt="{{ product.name }}"
                >
              {% elsif product.image != blank %}
                <img
                  src="{{ product.image }}"
                  class="w-3/4 h-3/4 object-contain group-hover:scale-110 transition-transform duration-500"
                  alt="{{ product.name }}"
                >
              {% else %}
                <svg
                  class="w-20 h-20 text-gray-200 group-hover:scale-110 transition-transform duration-500"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                </svg>
              {% endif %}

              <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-4 z-10">
                <button
                  data-product="{{ product | json | escape }}"
                  onclick="event.preventDefault(); window.addToCart(JSON.parse(this.dataset.product))"
                  class="bg-primary hover:bg-blue-600 text-white text-sm font-bold py-2 px-6 rounded-xl transition-colors shadow-lg shadow-primary/30 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
                >
                  Sepete Ekle
                </button>
              </div>
            </a>

            <div class="text-center mt-auto">
              <a href="/store/{{ server.slug }}/{{ category.slug }}/{{ product.slug }}">
                <h4 class="text-lg font-black text-gray-900 hover:text-primary transition-colors">
                  {{ product.name }}
                </h4>
              </a>
              <div class="flex items-center justify-center gap-2 mt-2">
                <span class="text-primary font-black text-xl">{{ product.price }} ₺</span>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  {% else %}
    <!-- Ürün Yok (Beyaz Tema) -->
    <div class="w-full bg-white border border-gray-100 rounded-3xl p-16 text-center shadow-sm">
      <div class="w-20 h-20 rounded-full bg-gray-50 border border-gray-100 flex items-center justify-center mx-auto mb-5 text-4xl shadow-inner">
        📭
      </div>
      <h2 class="text-2xl font-black text-gray-900 mb-2">Bu Kategoride Ürün Yok</h2>
      <p class="max-w-md mx-auto text-gray-500 font-medium">
        Henüz satışa sunulmuş ürün bulunmuyor. Lütfen daha sonra tekrar kontrol edin.
      </p>
      <a
        href="/store/{{ server.slug }}"
        class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-gray-500 bg-gray-50 py-3 px-6 rounded-xl hover:text-primary hover:bg-gray-100 transition-colors border border-gray-100"
      >
        ← {{ server.name }} Kategorilerine Dön
      </a>
    </div>
  {% endif %}
</div>

<!-- Sepete Ekleme Toast -->
<div
  id="cart-toast"
  class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-green-500 text-white px-6 py-3 rounded-full font-bold text-sm opacity-0 pointer-events-none transition-all duration-300 z-[9999] shadow-lg shadow-green-500/30 translate-y-4 flex items-center gap-2"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
  </svg>
  Başarıyla Sepete Eklendi!
</div>

<script>
  async function addToCart(productId) {
    try {
      const res = await fetch('/api/storefront/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, quantity: 1 }),
      });
      if (res.ok) {
        const t = document.getElementById('cart-toast');
        t.classList.remove('opacity-0', 'translate-y-4');
        setTimeout(() => {
          t.classList.add('opacity-0', 'translate-y-4');
        }, 2500);
      }
    } catch (e) {
      console.error('Sepete eklenemedi:', e);
    }
  }
</script>
