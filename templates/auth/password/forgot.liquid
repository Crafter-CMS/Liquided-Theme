{% if websiteData.security.cf_turnstile.site_key %}
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
{% endif %}
<div class="flex w-full h-screen bg-white overflow-hidden">
  <!-- LEFT SIDE: Auth Form -->
  <div class="w-full lg:w-1/2 flex flex-col items-center justify-center p-8 sm:p-12 lg:p-24 relative">
    <!-- Back to Login -->
    <a
      href="/auth"
      class="absolute top-8 left-8 flex items-center gap-2 text-gray-500 hover:text-primary transition-colors font-bold text-sm"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Giriş Sayfasına Dön
    </a>

    <div class="w-full max-w-md mx-auto">
      <!-- Logo -->
      <a href="/" class="block mb-8">
        {% if settings.logo %}
          <img src="{{ settings.logo }}" alt="{{ shop.name }}" class="h-16 object-contain">
        {% else %}
          <div class="font-display font-black text-3xl text-gray-900">{{ shop.name | upcase }}</div>
        {% endif %}
      </a>

      <!-- State Containers -->
      <div id="forgot-container" class="animate-[fade-in_300ms_ease-out]">
        <h1 class="text-3xl font-black text-gray-900 mb-2 tracking-tight">
          Şifremi Unuttum
        </h1>
        <p class="text-gray-500 font-medium mb-8">
          E-posta adresini gir, sana şifreni sıfırlaman için bir bağlantı gönderelim.
        </p>

        <form id="forgotForm" class="space-y-5">
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">E-posta Adresi</label>
            <input
              type="email"
              name="email"
              required
              placeholder="steve@minecraft.net"
              class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
            >
          </div>

          {% if websiteData.security.cf_turnstile.site_key %}
            <div class="cf-turnstile mt-2" data-sitekey="{{ websiteData.security.cf_turnstile.site_key }}"></div>
          {% endif %}

          <button
            type="submit"
            class="w-full bg-primary text-white font-bold rounded-xl px-4 py-3.5 hover:brightness-110 transition-all shadow-lg shadow-primary/30 flex items-center justify-center gap-2"
          >
            <span>Sıfırlama Bağlantısı Gönder</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- RIGHT SIDE: Image/Promo -->
  <div class="hidden lg:flex lg:w-1/2 relative bg-gray-900 overflow-hidden rounded-l-[3rem] shadow-2xl m-4">
    <img
      src="{% if settings.auth.background %}{{ settings.auth.background }}{% elsif settings.header.banner %}{{ settings.header.banner }}{% else %}https://images.unsplash.com/photo-1627856013091-fed6e4e30025?q=80&w=2070&auto=format&fit=crop{% endif %}"
      alt="Background"
      class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay"
    >
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

    <div class="relative z-10 flex flex-col justify-end p-16 h-full text-white">
      <h2 class="text-4xl font-black mb-4 tracking-tight whitespace-pre-line">
        {{ settings.auth.right_title | default: "Türkiye'nin En Büyük\nMinecraft Topluluğu" }}
      </h2>
      <p class="text-gray-300 font-medium text-lg max-w-lg mb-8 leading-relaxed whitespace-pre-line">
        {{
          settings.auth.right_description
          | default: 'Hemen aramıza katıl, arkadaşlarınla birlikte devasa haritalarda hayatta kal, mini oyunlarda yeteneklerini göster ve efsanevi ödüller kazan!'
        }}
      </p>

      <div class="flex items-center gap-3">
        <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse shadow-[0_0_10px_rgba(74,222,128,0.6)]"></div>
        <div>
          <div class="text-xs font-bold text-gray-400 uppercase tracking-widest">Çevrimiçi</div>
          <div class="font-black text-xl">
            <span id="auth-online-count" class="animate-pulse text-white">...</span>
            <span class="text-sm font-bold text-gray-300">Oyuncu</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Dynamic Online Players
  const serverIp = '{{ settings.server_ip | default: "play.crafter.com.tr" }}';
  async function fetchAuthServerStatus() {
    try {
      const res = await fetch(`https://mcapi.tr/api/v1/status/${serverIp}`);
      if (!res.ok) throw new Error('Primary API error');
      const data = await res.json();
      if (data.online && data.players) return data.players.online;
    } catch (e) {
      try {
        const res2 = await fetch(`https://api.mcsrvstat.us/3/${serverIp}`);
        if (!res2.ok) throw new Error('Fallback API error');
        const data2 = await res2.json();
        if (data2.online && data2.players) return data2.players.online;
      } catch (e2) {}
    }
    return null;
  }

  fetchAuthServerStatus().then(online => {
    const el = document.getElementById('auth-online-count');
    if (el) {
      el.classList.remove('animate-pulse');
      el.innerText = online !== null ? online : '?';
    }
  });

  // Handle Forgot Password
  document.getElementById('forgotForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData.entries());
    
    if (data['cf-turnstile-response']) {
      data.turnstileToken = data['cf-turnstile-response'];
      delete data['cf-turnstile-response'];
    }

    const btn = e.target.querySelector('button');
    const originalText = btn.innerHTML;

    btn.disabled = true;
    btn.innerHTML = '<span class="animate-pulse">Gönderiliyor...</span>';

    try {
      const res = await fetch('/api/storefront/v2/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = await res.json();

      if (result.success) {
        showToast('Şifre sıfırlama bağlantısı e-posta adresinize gönderildi.', 'success');
        e.target.reset();
      } else {
        showToast(result.message || 'Bir hata oluştu!', 'error');
      }
    } catch (err) {
      showToast('Bağlantı hatası!', 'error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalText;
    }
  });
</script>
